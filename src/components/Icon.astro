---
interface Props {
  name: string;
  decorative?: boolean;
  label?: string;
  class?: string;
}

const { name, decorative = true, label, class: className = '' } = Astro.props;
const ariaLabel = decorative ? undefined : label ?? name;
---

<svg
  class={`icon ${className}`}
  viewBox="0 0 24 24"
  fill="none"
  stroke="#2563eb"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={decorative ? 'true' : undefined}
  aria-label={ariaLabel}
  role={decorative ? undefined : 'img'}
>
  {name === 'horas' && (<><circle cx="12" cy="12" r="8" /><path d="M12 8v4l3 2" /></>)}
  {name === 'salario' && (<><path d="M4 8h16v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z" /><path d="M9 8V6a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" /></>)}
  {name === 'ferias' && (<><rect x="4" y="6" width="16" height="14" rx="2" /><path d="M8 4v4M16 4v4M4 10h16" /><circle cx="16.5" cy="15.5" r="2.5" /></>)}
  {name === 'rescisao' && (<><path d="M8 3h6l4 4v14H8z" /><path d="M14 3v4h4M10 12h6M10 16h4" /></>)}
  {name === 'decimo' && (<><circle cx="12" cy="12" r="8" /><path d="M9.5 14.5c.5 1 1.5 1.5 2.5 1.5 1.4 0 2.5-.8 2.5-2s-1.1-2-2.5-2-2.5-.8-2.5-2 1.1-2 2.5-2c1 0 1.9.4 2.4 1.3M12 7v10" /></>)}
  {name === 'horas-extras' && (<><circle cx="11" cy="12" r="7" /><path d="M11 8v4l2.5 1.5M18.5 6.5v4M16.5 8.5h4" /></>)}
  {name === 'financeiro' && (<><path d="M5 18h14" /><path d="M7 15l3-3 2 2 4-5" /><circle cx="18" cy="6" r="2" /></>)}
  {name === 'saude' && (<><path d="M12 19s-6-3.8-6-8a3.5 3.5 0 0 1 6-2.4A3.5 3.5 0 0 1 18 11c0 4.2-6 8-6 8z" /><path d="M9 12h2l1-2 1 4 1-2h1" /></>)}
  {name === 'matematica' && (<><rect x="7" y="4" width="10" height="16" rx="2" /><path d="M9.5 8h5M10 12h.01M12 12h.01M14 12h.01M10 15h.01M12 15h.01M14 15h.01" /></>)}
  {name === 'utilidades' && (<><path d="M14.5 5.5l4 4-8.8 8.8-4.3.9.9-4.3z" /><path d="M13 7l4 4" /></>)}
  {name !== 'horas' && name !== 'salario' && name !== 'ferias' && name !== 'rescisao' && name !== 'decimo' && name !== 'horas-extras' && name !== 'financeiro' && name !== 'saude' && name !== 'matematica' && name !== 'utilidades' && (<><circle cx="12" cy="12" r="8" /><path d="M12 9v3m0 3h.01" /></>)}
</svg>
