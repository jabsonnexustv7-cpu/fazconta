---
import Icon from './Icon.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  badge?: string;
  icon?: string;
}

const { title, description, href, badge = 'Calculadora', icon = 'utilidades' } = Astro.props;
---

<a class="calculator-card" href={href}>
  <div class="card-top">
    <span class="card-icon"><Icon name={icon} decorative={true} /></span>
    <span class="badge">{badge}</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <strong class="card-cta">Calcular agora →</strong>
</a>
