---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  items?: FAQItem[];
}

const {
  title = 'FAQ',
  subtitle = 'Respostas rápidas para você usar o FazConta com mais confiança.',
  items = [
    { question: 'As calculadoras são gratuitas?', answer: 'Sim. Todas as calculadoras do FazConta são gratuitas e podem ser usadas sem cadastro.' },
    { question: 'Posso usar no celular?', answer: 'Sim. O layout é responsivo e otimizado para uma navegação simples em telas pequenas.' },
    { question: 'Os resultados têm validade jurídica?', answer: 'Os resultados são estimativas para apoio. Para decisões formais, valide com um profissional.' }
  ]
} = Astro.props;
---
<section class="faq section">
  <div class="section-head">
    <h2>{title}</h2>
    <p class="lead">{subtitle}</p>
  </div>
  <div class="faq-grid">
    {items.map((item) => (
      <article>
        <h3>{item.question}</h3>
        <p>{item.answer}</p>
      </article>
    ))}
  </div>
</section>
