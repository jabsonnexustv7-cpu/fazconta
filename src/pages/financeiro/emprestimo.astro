---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import AdSlot from '../../components/AdSlot.astro';
const faqItems=[{question:'O resultado é oficial?',answer:'Não. É uma simulação para planejamento.'},{question:'Posso usar no celular?',answer:'Sim, a calculadora funciona em dispositivos móveis.'},{question:'Este cálculo substitui análise profissional?',answer:'Não. Use como apoio e valide condições reais.'},{question:'Os valores têm arredondamento?',answer:'Sim, para facilitar leitura em reais e percentuais.'}];
---
<BaseLayout title="Calculadora de Empréstimo | FazConta" description="Simule parcela e custo total de empréstimo."><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Financeiro',href:'/financeiro'},{label:'Calculadora de Empréstimo'}]} /><h1>Calculadora de Empréstimo</h1><p class='lead'>Simule parcela e custo total de empréstimo.</p><p class='help-text'><strong>Aviso:</strong> cálculo estimativo para planejamento.</p><AdSlot /><div class='form-grid'><label>Valor emprestado (R$)<input id='pv' type='number' step='0.01' value='10000'></label><label>Taxa mensal (%)<input id='i' type='number' step='0.01' value='2'></label><label>Prazo (meses)<input id='n' type='number' step='1' value='24'></label><label>Tarifas (R$)<input id='tar' type='number' step='0.01' value='0'></label></div><button class='btn' id='calc'>Calcular</button><div class='result-card'><p class='result-title'>Resultado</p><p class='result-value' id='res'>-</p><p class='result-detail' id='det'></p></div><h2>Como usar esta calculadora</h2><p>Preencha os campos com seus valores reais e clique em calcular.</p><h2>Como o cálculo é feito</h2><p>Aplicamos fórmula financeira/matemática padrão com exibição do breakdown.</p><h2>Exemplo prático</h2><p>Teste com valores próximos da sua realidade para comparar cenários.</p><h2>Calculadoras relacionadas</h2><ul><li><a href='/financeiro/financiamento'>financiamento</a></li><li><a href='/financeiro/juros-compostos'>juros compostos</a></li><li><a href='/financeiro/reserva-emergencia'>reserva emergencia</a></li><li><a href='/financeiro'>Ver categoria financeiro</a></li><li><a href='/blog'>Ver blog</a></li></ul><FAQSection items={faqItems} /><FAQSchema items={faqItems} /></section><script>const f=n=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});calc.onclick=()=>{const pv0=+pv.value||0,j=(+i.value||0)/100,nm=+n.value||1,tar0=+tar.value||0;const pm=pv0*(j*Math.pow(1+j,nm))/(Math.pow(1+j,nm)-1);const total=pm*nm+tar0;res.textContent=f(pm);det.textContent=`Parcela mensal · Total pago ${f(total)} · Juros+tarifas ${f(total-pv0)}`};</script></BaseLayout>