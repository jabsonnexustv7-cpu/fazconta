---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import AdSlot from '../../components/AdSlot.astro';
const faqItems=[{question:'O resultado é oficial?',answer:'Não. É uma simulação para planejamento.'},{question:'Posso usar no celular?',answer:'Sim, a calculadora funciona em dispositivos móveis.'},{question:'Este cálculo substitui análise profissional?',answer:'Não. Use como apoio e valide condições reais.'},{question:'Os valores têm arredondamento?',answer:'Sim, para facilitar leitura em reais e percentuais.'}];
---
<BaseLayout title="Simulador de Selic | FazConta" description="Projete rendimento por percentual do Selic e prazo."><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Financeiro',href:'/financeiro'},{label:'Simulador de Selic'}]} /><h1>Simulador de Selic</h1><p class='lead'>Projete rendimento por percentual do Selic e prazo.</p><p class='help-text'><strong>Aviso:</strong> cálculo estimativo para planejamento.</p><AdSlot /><div class='form-grid'><label>Valor inicial (R$)<input id='ap' type='number' step='0.01' value='1000'></label><label>Aporte mensal (R$)<input id='am' type='number' step='0.01' value='0'></label><label>% do Selic ao ano<input id='tx' type='number' step='0.01' value='100'></label><label>Prazo (meses)<input id='n' type='number' step='1' value='12'></label></div><button class='btn' id='calc'>Calcular</button><div class='result-card'><p class='result-title'>Resultado</p><p class='result-value' id='res'>-</p><p class='result-detail' id='det'></p></div><h2>Como usar esta calculadora</h2><p>Preencha os campos com seus valores reais e clique em calcular.</p><h2>Como o cálculo é feito</h2><p>Aplicamos fórmula financeira/matemática padrão com exibição do breakdown.</p><h2>Exemplo prático</h2><p>Teste com valores próximos da sua realidade para comparar cenários.</p><h2>Calculadoras relacionadas</h2><ul><li><a href='/financeiro/selic'>selic</a></li><li><a href='/financeiro/juros-compostos'>juros compostos</a></li><li><a href='/financeiro/poupanca'>poupanca</a></li><li><a href='/financeiro'>Ver categoria financeiro</a></li><li><a href='/blog'>Ver blog</a></li></ul><FAQSection items={faqItems} /><FAQSchema items={faqItems} /></section><script>const f=n=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});calc.onclick=()=>{const p=+ap.value||0,m=+am.value||0,i=((+tx.value||0)/100)/12,t=+n.value||0;let mont=p;for(let k=0;k<t;k++)mont=(mont+m)*(1+i);res.textContent=f(mont);det.textContent=`Total investido ${f(p+m*t)} · Rendimentos ${f(mont-(p+m*t))}`};</script></BaseLayout>