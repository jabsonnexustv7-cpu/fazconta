---import BaseLayout from '../../layouts/BaseLayout.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';import CalculatorSEOContent from '../../components/CalculatorSEOContent.astro';---
<BaseLayout title="Calculadora de Juros Compostos | FazConta" description="Projeção de investimentos com capital inicial, aportes e taxa."><section class="container section calc-layout"><article class="calc-form"><h1>Juros Compostos</h1><AdSlot /><div class="form-grid"><label>Capital inicial<input id="ci" type="number" /></label><label>Aporte mensal<input id="ap" type="number" value="0" /></label><label>Taxa de juros (%)<input id="tx" type="number" step="0.01" /></label><label>Tipo<select id="tp"><option value="m">Mensal</option><option value="a">Anual</option></select></label><label>Prazo (meses)<input id="p" type="number" value="120" /></label></div><button class="btn" id="c">Calcular</button></article><aside class="calc-result"><div class="result-card"><p class="result-title">Montante final</p><p class="result-value" id="r">R$ 0,00</p><p id="d" class="result-detail"></p></div><table class="calc-table" id="tb"></table></aside></section><script>const f=n=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});c.onclick=()=>{let m=+ci.value||0;const apm=+ap.value||0,mes=+p.value||0,txm=(+tx.value||0)/100,rate=tp.value==='a'?Math.pow(1+txm,1/12)-1:txm;tb.innerHTML='<tr><th>Ano</th><th>Saldo</th></tr>';for(let i=1;i<=mes;i++){m=m*(1+rate)+apm;if(i%12===0)tb.innerHTML+=`<tr><td>${i/12}</td><td>${f(m)}</td></tr>`;}const inv=(+ci.value||0)+apm*mes,ju=m-inv;r.textContent=f(m);d.textContent=`Total investido ${f(inv)} · Total de juros ${f(ju)}`}</script><CalculatorSEOContent title="Juros Compostos" /><div class="container"><AdSlot /><FAQSection items={[{question:'Taxa anual vira mensal?',answer:'Sim, por equivalência.'},{question:'Aporte no fim do mês?',answer:'Sim, neste modelo.'},{question:'Serve para renda fixa?',answer:'Como simulação inicial.'},{question:'Tabela anual inclusa?',answer:'Sim.'}]} /></div></BaseLayout>
