---import BaseLayout from '../../layouts/BaseLayout.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';---
<BaseLayout title="Calculadora de Financiamento | FazConta" description="Estime parcela, total pago e juros do financiamento."><section class="container section calc-layout"><article class="calc-form"><h1>Financiamento</h1><AdSlot /><div class="form-grid"><label>Valor do bem<input id="vb" type="number" /></label><label>Entrada<input id="en" type="number" value="0" /></label><label>Taxa mensal (%)<input id="tx" type="number" step="0.01" /></label><label>Prazo (meses)<input id="n" type="number" value="60" /></label></div><button class="btn" id="c">Calcular</button></article><aside class="calc-result"><div class="result-card"><p class="result-title">Parcela mensal estimada</p><p class="result-value" id="r">R$ 0,00</p><p id="d" class="result-detail"></p></div><table class="calc-table" id="t"></table></aside></section><script>const f=n=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});c.onclick=()=>{const pv=(+vb.value||0)-(+en.value||0),i=(+tx.value||0)/100,mes=+n.value||1,p= pv*(i*Math.pow(1+i,mes))/(Math.pow(1+i,mes)-1),tot=p*mes,ju=tot-pv;r.textContent=f(p);d.textContent=`Valor financiado ${f(pv)} · Total pago ${f(tot)} · Juros ${f(ju)}`;let sd=pv;t.innerHTML='<tr><th>Parcela</th><th>Juros</th><th>Amortização</th><th>Saldo</th></tr>';const rows=[];for(let k=1;k<=mes;k++){const j=sd*i,a=p-j;sd-=a;rows.push([k,j,a,Math.max(sd,0)]);}const show=[...rows.slice(0,3),...rows.slice(-3)];show.forEach(x=>t.innerHTML+=`<tr><td>${x[0]}</td><td>${f(x[1])}</td><td>${f(x[2])}</td><td>${f(x[3])}</td></tr>`);}</script><div class="container"><AdSlot /><FAQSection items={[{question:'Sistema Price?',answer:'Sim, fórmula de parcela fixa.'},{question:'Mostra tabela completa?',answer:'Mostra 3 primeiras e 3 últimas.'},{question:'Taxa efetiva?',answer:'Use taxa mensal estimada.'},{question:'Inclui seguros?',answer:'Não.'}]} /></div></BaseLayout>
