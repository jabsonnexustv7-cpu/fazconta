---
import BaseLayout from '../../layouts/BaseLayout.astro';import Breadcrumb from '../../components/Breadcrumb.astro';import AdSlot from '../../components/AdSlot.astro';import FAQSection from '../../components/FAQSection.astro';import FAQSchema from '../../components/FAQSchema.astro';
const faqItems=[{question:'INCC é obrigatório?',answer:'Depende do contrato; muitos imóveis na planta usam índice de correção.'},{question:'Qual diferença entre acumulado e mensal?',answer:'O acumulado cobre todo o período; o mensal é a taxa equivalente de cada mês.'},{question:'O valor final é exato?',answer:'Não, a simulação é estimativa e o contrato pode ter regras próprias.'},{question:'Posso usar para saldo devedor?',answer:'Sim, como projeção para acompanhar evolução da dívida corrigida.'}];
---
<BaseLayout title='Calculadora de INCC | FazConta' description='Simule correção de parcelas ou saldo devedor pelo INCC com aplicação única ou mês a mês.'><section class='container section'><Breadcrumb items={[{label:'Home',href:'/'},{label:'Financeiro',href:'/financeiro'},{label:'INCC'}]} /><h1>Calculadora de INCC</h1><p class='lead'>Simule a correção de parcelas ou saldo devedor pelo INCC de forma simples e estimativa.</p><AdSlot />
<div class='calc-layout'><form class='calc-form' id='incc-form'><div class='form-grid'><label>Valor base (R$)<input name='base' type='number' step='0.01' required/></label><label>INCC acumulado no período (%)<input name='incc' type='number' step='0.01' required/></label><label>Número de meses/parcelas<input name='meses' type='number' min='1' required/></label><label>Forma de aplicação<select name='modo'><option value='unica'>Correção única</option><option value='mensal'>Mês a mês</option></select></label></div><button class='btn'>Calcular INCC</button></form><div class='calc-result'><h2 class='result-title'>Resultado</h2><p class='result-value' id='incc-valor'>--</p><p class='result-detail' id='incc-detalhe'>--</p><div id='incc-tabela' class='help-text'></div></div></div>
<h2>Como usar esta calculadora</h2><p>Informe valor base, INCC acumulado e período. Selecione correção única para aplicar tudo de uma vez, ou mês a mês para simular capitalização equivalente.</p><h2>Como o cálculo é feito</h2><p>Correção única: valor corrigido = valor base × (1 + INCC/100). Mês a mês: taxa mensal = (1 + INCC acumulado/100)^(1/meses) - 1 e capitalização até o fim.</p><p><strong>Aviso:</strong> resultado estimativo. Contratos de construção e imóvel na planta podem prever regras específicas.</p><p><a href='/financeiro/financiamento'>Financiamento</a> · <a href='/financeiro/juros-compostos'>Juros compostos</a> · <a href='/financeiro/reserva-de-emergencia'>Reserva de emergência</a> · <a href='/financeiro'>Categoria financeiro</a> · <a href='/blog'>Blog</a></p>
<FAQSection title='FAQ de INCC' items={faqItems}/><FAQSchema items={faqItems}/></section>
<script>document.getElementById('incc-form')?.addEventListener('submit',(e)=>{e.preventDefault();const f=e.currentTarget;const base=Number(f.base.value);const incc=Number(f.incc.value)/100;const meses=Number(f.meses.value);const modo=f.modo.value;let valor=base;let tabela='';if(modo==='unica'){valor=base*(1+incc);}else{const tx=(Math.pow(1+incc,1/meses)-1);for(let i=1;i<=meses;i++){valor*=1+tx;tabela+=`Mês ${i}: ${valor.toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}<br>`;}}const dif=valor-base;document.getElementById('incc-valor').textContent=`Valor corrigido: ${valor.toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}`;document.getElementById('incc-detalhe').textContent=`Diferença: ${dif.toLocaleString('pt-BR',{style:'currency',currency:'BRL'})} | Percentual aplicado: ${(incc*100).toFixed(2)}%`;document.getElementById('incc-tabela').innerHTML=modo==='mensal'?tabela:'';});</script></BaseLayout>
