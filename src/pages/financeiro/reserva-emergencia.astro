---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import AdSlot from '../../components/AdSlot.astro';
const faqItems=[{question:'O resultado é oficial?',answer:'Não. É uma simulação para planejamento.'},{question:'Posso usar no celular?',answer:'Sim, a calculadora funciona em dispositivos móveis.'},{question:'Este cálculo substitui análise profissional?',answer:'Não. Use como apoio e valide condições reais.'},{question:'Os valores têm arredondamento?',answer:'Sim, para facilitar leitura em reais e percentuais.'}];
---
<BaseLayout title="Calculadora de Reserva de Emergência | FazConta" description="Descubra sua meta de reserva e tempo para atingir."><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Financeiro',href:'/financeiro'},{label:'Calculadora de Reserva de Emergência'}]} /><h1>Calculadora de Reserva de Emergência</h1><p class='lead'>Descubra sua meta de reserva e tempo para atingir.</p><p class='help-text'><strong>Aviso:</strong> cálculo estimativo para planejamento.</p><AdSlot /><div class='form-grid'><label>Gasto mensal (R$)<input id='g' type='number' step='0.01' value='3000'></label><label>Meses de segurança<input id='m' type='number' step='1' value='6'></label><label>Aporte mensal (R$)<input id='a' type='number' step='0.01' value='500'></label><label>Rendimento mensal (%)<input id='r' type='number' step='0.01' value='0.6'></label></div><button class='btn' id='calc'>Calcular</button><div class='result-card'><p class='result-title'>Resultado</p><p class='result-value' id='res'>-</p><p class='result-detail' id='det'></p></div><h2>Como usar esta calculadora</h2><p>Preencha os campos com seus valores reais e clique em calcular.</p><h2>Como o cálculo é feito</h2><p>Aplicamos fórmula financeira/matemática padrão com exibição do breakdown.</p><h2>Exemplo prático</h2><p>Teste com valores próximos da sua realidade para comparar cenários.</p><h2>Calculadoras relacionadas</h2><ul><li><a href='/financeiro/cdi'>cdi</a></li><li><a href='/financeiro/selic'>selic</a></li><li><a href='/financeiro/emprestimo'>emprestimo</a></li><li><a href='/financeiro'>Ver categoria financeiro</a></li><li><a href='/blog'>Ver blog</a></li></ul><FAQSection items={faqItems} /><FAQSchema items={faqItems} /></section><script>const f=n=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});calc.onclick=()=>{const meta=(+g.value||0)*(+m.value||0),ap=+a.value||0,i=(+r.value||0)/100;let s=0,k=0;while(s<meta&&k<600){s=(s+ap)*(1+i);k++}res.textContent=f(meta);det.textContent=`Meta total · Saldo projetado ${f(s)} · Prazo estimado ${k} meses`};</script></BaseLayout>