---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
const cards=['cdi','selic','poupanca','emprestimo','reserva-emergencia','juros-compostos','financiamento'];
const faqItems=[{question:'As simulações são oficiais?',answer:'Não. São estimativas para planejamento financeiro.'},{question:'Posso comparar cenários?',answer:'Sim, altere taxa, prazo e aportes para comparar.'},{question:'Tem custos de banco inclusos?',answer:'Nem sempre. Verifique tarifas e impostos no contrato.'},{question:'Substitui consultoria?',answer:'Não. Use como apoio para decisão.'}];
---
<BaseLayout title='Financeiro | FazConta' description='Calculadoras financeiras para investimentos, crédito e planejamento.'><section class='container section'><h1>Calculadoras financeiras do FazConta</h1><p class='lead'>Planeje investimentos, dívidas e reserva com simulações claras.</p><h2>Todas as calculadoras</h2><div class='cards-grid'>{cards.map((s)=><CalculatorCard title={s.replaceAll('-',' ')} href={`/financeiro/${s}`} description='Simulação financeira específica' badge='Financeiro' icon='financeiro' />)}</div><h2>Mais acessadas</h2><ul><li><a href='/financeiro/cdi'>CDI</a></li><li><a href='/financeiro/juros-compostos'>Juros compostos</a></li><li><a href='/financeiro/emprestimo'>Empréstimo</a></li></ul><p><a href='/blog'>Ver conteúdos no blog</a></p><FAQSection items={faqItems} /><FAQSchema items={faqItems} /></section></BaseLayout>