---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import FAQSection from '../../components/FAQSection.astro';
const cards=['cdi','selic','poupanca','emprestimo','cartao-de-credito','parcelamento','reserva-de-emergencia','conversor-de-moeda','investimento-mensal'];
---
<BaseLayout title="Calculadoras Financeiras | FazConta" description="CDI, Selic, poupança, empréstimo e mais.">
<section class="container section"><h1>Calculadoras Financeiras</h1><p class="lead">Planeje investimentos e crédito com simulações rápidas.</p><div class="cards-grid">{cards.map((s)=><CalculatorCard title={s.replaceAll('-',' ')} href={`/financeiro/${s}`} description="Simulador financeiro" badge="Financeiro" icon="💰" />)}</div></section>
<div class="container"><FAQSection title="FAQ financeiro" /></div>
</BaseLayout>
