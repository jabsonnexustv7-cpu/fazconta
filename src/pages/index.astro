---
const title = 'FazConta';
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Calculadoras online grátis para salário, férias, rescisão, horas trabalhadas e muito mais."
    />

    <style>
      :root {
        --bg: #071226;
        --card: #0f1d35;
        --primary: #2563eb;
        --text: #ffffff;
        --muted: #b6c2d9;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      .container {
        width: 100%;
        max-width: 1100px;
        margin: auto;
        padding: 24px;
      }

      header {
        padding: 24px 0;
      }

      .logo {
        font-size: 32px;
        font-weight: bold;
      }

      .hero {
        padding: 60px 0;
      }

      .hero h1 {
        font-size: 52px;
        line-height: 1.1;
        margin-bottom: 20px;
      }

      .hero p {
        font-size: 20px;
        color: var(--muted);
        max-width: 700px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
        margin-top: 40px;
      }

      .card {
        background: var(--card);
        border-radius: 18px;
        padding: 24px;
        text-decoration: none;
        color: white;
        transition: 0.2s ease;
        border: 1px solid rgba(255,255,255,0.05);
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: rgba(37,99,235,0.7);
      }

      .card h3 {
        margin-bottom: 10px;
      }

      .card p {
        color: var(--muted);
        line-height: 1.5;
      }

      .badge {
        display: inline-block;
        background: rgba(37,99,235,0.15);
        color: #7db0ff;
        padding: 8px 14px;
        border-radius: 999px;
        margin-bottom: 20px;
        font-size: 14px;
      }

      footer {
        padding: 50px 0;
        color: var(--muted);
        font-size: 14px;
      }

      @media (max-width: 768px) {
        .hero h1 {
          font-size: 38px;
        }

        .hero p {
          font-size: 18px;
        }
      }
    </style>
  </head>

  <body>
    <div class="container">
      <header>
        <div class="logo">FazConta</div>
      </header>

      <section class="hero">
        <div class="badge">Calculadoras online grátis</div>

        <h1>
          Simule salário, férias,
          rescisão e muito mais.
        </h1>

        <p>
          Ferramentas rápidas, simples e gratuitas para cálculos trabalhistas,
          financeiros e do dia a dia.
        </p>
      </section>

      <section>
        <h2>Categoria Trabalhista</h2>

        <div class="grid">
          <a class="card" href="/trabalhista/horas-trabalhadas">
            <h3>Horas Trabalhadas</h3>
            <p>
              Calcule horas trabalhadas online com intervalo automaticamente.
            </p>
          </a>

          <div class="card">
            <h3>Salário Líquido</h3>
            <p>
              Em breve.
            </p>
          </div>

          <div class="card">
            <h3>Férias</h3>
            <p>
              Em breve.
            </p>
          </div>
        </div>
      </section>

      <footer>
        © 2026 FazConta — Calculadoras online gratuitas.
      </footer>
    </div>
  </body>
</html>
