---
import BaseLayout from '../layouts/BaseLayout.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import FAQSection from '../components/FAQSection.astro';
---

<BaseLayout title="FazConta | Calculadoras com experiência premium" description="Faça simulações trabalhistas em segundos com interface premium e resultados claros.">
  <section class="hero container">
    <div>
      <span class="hero-chip">Plataforma de cálculo inteligente</span>
      <h1>Faça contas complexas com clareza de produto premium.</h1>
      <p>O FazConta combina velocidade, design moderno e resultados objetivos para te ajudar a decidir melhor no dia a dia financeiro e trabalhista.</p>
      <div class="hero-actions">
        <a class="btn" href="/trabalhista">Usar calculadora</a>
        <a class="btn btn-ghost" href="#mais-acessadas">Ver mais acessadas</a>
      </div>
      <div class="search-shell">
        <input type="search" placeholder="Busque uma calculadora: salário, férias, horas..." aria-label="Buscar calculadoras" />
      </div>
    </div>
    <aside class="hero-panel">
      <p class="result-title">Resultado estimado</p>
      <p class="result-value">R$ 4.283,40</p>
      <div class="result-split">
        <div><span>INSS</span><strong>R$ 512,00</strong></div>
        <div><span>IRRF</span><strong>R$ 204,60</strong></div>
        <div><span>Líquido</span><strong>R$ 3.566,80</strong></div>
      </div>
      <small>Simulação visual para demonstrar o formato dos resultados.</small>
    </aside>
  </section>

  <section class="container section" id="mais-acessadas">
    <div class="section-head"><h2>Mais acessadas</h2></div>
    <div class="cards-grid">
      <CalculatorCard icon="⏱" title="Horas Trabalhadas" description="Calcule jornada líquida com intervalo e virada de turno." href="/trabalhista/horas-trabalhadas" badge="Jornada" />
      <CalculatorCard icon="💼" title="Salário Líquido" description="Simule descontos e veja o valor aproximado na conta." href="/trabalhista/salario-liquido" badge="Salário" />
      <CalculatorCard icon="🌴" title="Férias" description="Estime férias com adicional de 1/3 e abono." href="/trabalhista/ferias" badge="Benefício" />
    </div>
  </section>

  <section class="container section why">
    <div class="section-head"><h2>Por que usar o FazConta</h2></div>
    <div class="why-grid">
      <article><h3>Experiência fluida</h3><p>Layout limpo, foco total no cálculo e leitura rápida dos números.</p></article>
      <article><h3>Estimativa transparente</h3><p>Você entende cada etapa do resultado com divisão clara por componentes.</p></article>
      <article><h3>Feito para mobile</h3><p>Botões grandes, textos legíveis e estrutura elegante em qualquer tela.</p></article>
    </div>
  </section>

  <div class="container"><FAQSection /></div>
</BaseLayout>
