---
import BaseLayout from '../layouts/BaseLayout.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import FAQSection from '../components/FAQSection.astro';

const calculators = [
  { title: 'Salário Líquido', href: '/trabalhista/salario-liquido', description: 'INSS, IRRF e descontos adicionais.', category: 'Trabalhista', icon: '💼' },
  { title: 'Horas Trabalhadas', href: '/trabalhista/horas-trabalhadas', description: 'Jornada líquida e saldo diário.', category: 'Trabalhista', icon: '⏱' },
  { title: 'Férias', href: '/trabalhista/ferias', description: 'Férias com 1/3, abono e descontos.', category: 'Trabalhista', icon: '🌴' },
  { title: 'Rescisão', href: '/trabalhista/rescisao', description: 'Estimativa de verbas rescisórias.', category: 'Trabalhista', icon: '📄' },
  { title: 'Décimo Terceiro', href: '/trabalhista/decimo-terceiro', description: 'Cálculo da 1ª e 2ª parcela.', category: 'Trabalhista', icon: '🎁' },
  { title: 'Horas Extras', href: '/trabalhista/horas-extras', description: 'HE 50%, 100% e noturna.', category: 'Trabalhista', icon: '⚡' },
  { title: 'Juros Compostos', href: '/financeiro/juros-compostos', description: 'Projeção com aportes e evolução anual.', category: 'Financeiro', icon: '📈' },
  { title: 'Financiamento', href: '/financeiro/financiamento', description: 'Parcela estimada e visão de amortização.', category: 'Financeiro', icon: '🏠' },
  { title: 'IMC', href: '/utilidades/imc', description: 'IMC, classificação e peso ideal.', category: 'Utilidades', icon: '🩺' },
  { title: 'Porcentagem', href: '/utilidades/porcentagem', description: '3 modos de cálculo percentual.', category: 'Utilidades', icon: '🧮' }
];
---
<BaseLayout title="FazConta | Calculadoras trabalhistas, financeiras e utilidades" description="Plataforma premium com calculadoras trabalhistas, financeiras e utilidades em um só lugar.">
  <section class="hero container">
    <div>
      <span class="hero-chip">Cálculos com UX premium</span>
      <h1>Encontre a calculadora ideal em segundos.</h1>
      <p>Busque por tema e simule resultados com visual claro, SEO técnico e foco mobile.</p>
      <div class="search-shell"><input id="search-calc" type="search" placeholder="Busque: férias, juros, porcentagem..." /></div>
    </div>
    <aside class="hero-panel"><p class="result-title">Total disponível</p><p class="result-value">10 calculadoras</p></aside>
  </section>
  <section class="container section" id="mais-acessadas"><div class="section-head"><h2>Mais acessadas</h2></div><div class="cards-grid">{calculators.slice(0,4).map((c)=><CalculatorCard title={c.title} description={c.description} href={c.href} badge={c.category} icon={c.icon} />)}</div></section>
  <section class="container section"><div class="section-head"><h2>Novas calculadoras</h2></div><div class="cards-grid">{calculators.slice(3,8).map((c)=><CalculatorCard title={c.title} description={c.description} href={c.href} badge={c.category} icon={c.icon} />)}</div></section>
  <section class="container section"><div class="section-head"><h2>Todas as calculadoras</h2></div><div class="cards-grid" id="all-calcs">{calculators.map((c)=><article data-title={c.title.toLowerCase()} data-description={c.description.toLowerCase()}><CalculatorCard title={c.title} description={c.description} href={c.href} badge={c.category} icon={c.icon} /></article>)}</div></section>
  <div class="container"><FAQSection /></div>
  <script>
    const input = document.getElementById('search-calc');
    const items = document.querySelectorAll('#all-calcs article');
    input?.addEventListener('input', () => {
      const query = input.value.toLowerCase().trim();
      items.forEach((item) => {
        const show = item.dataset.title.includes(query) || item.dataset.description.includes(query);
        item.style.display = show ? '' : 'none';
      });
    });
  </script>
</BaseLayout>
