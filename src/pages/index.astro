---
import BaseLayout from '../layouts/BaseLayout.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import FAQSection from '../components/FAQSection.astro';
import { calculadorasSeo } from "../data/calculadoras";
const calculators=calculadorasSeo.map((c)=>({title:c.titulo,href:c.rota,description:c.descricao,category:c.categoria||"Calculadora",icon:"utilidades"}));
const featured=[
{title:'Salário líquido',href:'/trabalhista/salario-liquido',description:'INSS e IRRF',category:'Trabalhista',icon:'salario'}];
---
<BaseLayout title="FazConta | Portal de calculadoras" description="Portal de calculadoras trabalhistas, financeiras, utilidades, saúde e matemática.">
<section class="hero container"><div><span class="hero-chip">FazConta</span><h1>Calculadoras simples para o dia a dia</h1><p>Simule salário, férias, rescisão, juros, IMC e muito mais em poucos segundos.</p><div class="search-shell"><input id="search-calc" type="search" placeholder="Busque por FGTS, CDI, IMC, regra de três..." /></div></div><aside class="hero-panel"><p class="result-title">Mais de 5 áreas</p><p class="result-value">Rápido, claro e gratuito</p></aside></section>

<section class="container section"><h2>Todas as calculadoras disponíveis</h2><div class="cards-grid" id="all-calcs">{calculators.map((c)=><article data-title={c.title.toLowerCase()} data-description={c.description.toLowerCase()} data-category={c.category.toLowerCase()}><CalculatorCard title={c.title} description={c.description} href={c.href} badge={c.category} icon={c.icon} /></article>)}</div></section>

<section class="container section"><h2>Mais usadas</h2><div class="cards-grid"><CalculatorCard title="Salário líquido" href="/trabalhista/salario-liquido" description="INSS, IRRF e descontos" badge="Trabalhista" icon="salario" /><CalculatorCard title="Juros compostos" href="/financeiro/juros-compostos" description="Simule aportes e rendimentos" badge="Financeiro" icon="financeiro" /><CalculatorCard title="IMC" href="/utilidades/imc" description="Avalie sua faixa de peso" badge="Utilidades" icon="saude" /></div></section>

<section class="container section"><h2>Categorias</h2><div class="cards-grid"><CalculatorCard title="Trabalhista" href="/trabalhista" description="Folha e direitos" badge="Categoria" icon="salario" /><CalculatorCard title="Financeiro" href="/financeiro" description="Investimentos e crédito" badge="Categoria" icon="financeiro" /><CalculatorCard title="Utilidades" href="/utilidades" description="Conversores" badge="Categoria" icon="utilidades" /><CalculatorCard title="Saúde" href="/saude" description="Bem-estar" badge="Categoria" icon="saude" /><CalculatorCard title="Matemática" href="/matematica" description="Operações" badge="Categoria" icon="matematica" /></div></section>

<section class="container section"><h2>Guias úteis</h2><div class="cards-grid">
<a class="calc-card" href="/blog/como-calcular-salario-liquido"><h3>Como calcular salário líquido</h3></a>
<a class="calc-card" href="/blog/como-calcular-ferias"><h3>Como calcular férias</h3></a>
<a class="calc-card" href="/blog/como-calcular-rescisao"><h3>Como calcular rescisão</h3></a>
<a class="calc-card" href="/blog/como-calcular-juros-compostos"><h3>Como calcular juros compostos</h3></a>
<a class="calc-card" href="/blog/como-calcular-imc"><h3>Como calcular IMC</h3></a>
<a class="calc-card" href="/blog/como-calcular-porcentagem"><h3>Como calcular porcentagem</h3></a>
</div></section>

<div class="container"><FAQSection title="FAQ FazConta" subtitle="Perguntas simples para usar as calculadoras com confiança." /></div>
<script>const input=document.getElementById('search-calc');const items=document.querySelectorAll('#all-calcs article');input?.addEventListener('input',()=>{const q=input.value.toLowerCase().trim();items.forEach((i)=>{i.style.display=[i.dataset.title,i.dataset.description,i.dataset.category].some((v)=>v.includes(q))?'':'none';});});</script>
</BaseLayout>
