---
import BaseLayout from '../layouts/BaseLayout.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import FAQSection from '../components/FAQSection.astro';
---

<BaseLayout title="FazConta | Simuladores online" description="Calculadoras trabalhistas premium para horas, salário líquido e férias.">
  <section class="hero container">
    <span class="hero-chip">Calculadoras online confiáveis</span>
    <h1>Transforme cálculos complexos em decisões rápidas.</h1>
    <p>Tenha estimativas trabalhistas e financeiras com visual claro, performance rápida e resultados instantâneos.</p>
  </section>

  <section class="container section">
    <h2>Calculadoras em destaque</h2>
    <div class="cards-grid">
      <CalculatorCard title="Horas Trabalhadas" description="Calcule jornada líquida diária com desconto de intervalo e virada de turno." href="/trabalhista/horas-trabalhadas" badge="Trabalhista" />
      <CalculatorCard title="Salário Líquido" description="Simule INSS e IRRF e descubra o valor aproximado que cai na conta." href="/trabalhista/salario-liquido" badge="Trabalhista" />
      <CalculatorCard title="Férias" description="Descubra valor bruto, adicional de 1/3 e descontos de forma simples." href="/trabalhista/ferias" badge="Trabalhista" />
    </div>
  </section>

  <div class="container"><FAQSection /></div>
</BaseLayout>
