---
import BaseLayout from '../../layouts/BaseLayout.astro'; import FAQSection from '../../components/FAQSection.astro'; import AdSlot from '../../components/AdSlot.astro';import CalculatorSEOContent from '../../components/CalculatorSEOContent.astro';
---
<BaseLayout title="Calculadora de Salário Líquido 2026 | FazConta" description="Simule salário líquido com INSS, IRRF e descontos adicionais."><section class="container section calc-layout"><article class="calc-form"><h1>Calculadora de Salário Líquido</h1><p class="lead">Resultado estimativo, pode variar conforme regras oficiais e descontos da empresa.</p><AdSlot /><div class="form-grid"><label>Salário bruto<input id="bruto" type="number" step="0.01" /></label><label>Dependentes<input id="deps" type="number" value="0" /></label><label>Vale-transporte descontado<input id="vt" type="number" step="0.01" value="0" /></label><label>Vale-refeição descontado<input id="vr" type="number" step="0.01" value="0" /></label><label>Plano de saúde descontado<input id="saude" type="number" step="0.01" value="0" /></label><label>Outros descontos<input id="outros" type="number" step="0.01" value="0" /></label></div><button class="btn" id="calc">Calcular</button></article><aside class="calc-result"><div class="result-card"><p class="result-title">Salário líquido em destaque</p><p class="result-value" id="liq">R$ 0,00</p><p class="result-detail" id="det"></p></div><AdSlot /><div class="related-links"><a href="/trabalhista/decimo-terceiro">Décimo terceiro</a><a href="/trabalhista/ferias">Férias</a></div></aside></section><section class="container section"><h2>Como usar esta calculadora</h2><p class="help-text">Preencha os campos e clique em calcular. Exemplo: bruto R$ 5.000, 1 dependente e R$ 600 de descontos adicionais.</p></section><div class="container"><AdSlot /><FAQSection items={[{question:'A tabela é oficial?',answer:'A base é estimativa conforme faixas públicas.'},{question:'Inclui todos os descontos?',answer:'Não. Descontos específicos podem variar por empresa.'},{question:'Posso usar para holerite?',answer:'Use como referência inicial.'},{question:'Dependentes impactam IRRF?',answer:'Sim, reduzem a base de cálculo.'}]} /></div><script>const f=(n)=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});const inssCalc=(b)=>{const t=[[1518,.075],[2793.88,.09],[4190.83,.12],[8157.41,.14]];let p=0,a=0;for(const [l,r] of t){const faixa=Math.min(b,l)-p;if(faixa>0)a+=faixa*r;p=l;}return a};const irrf=(base)=>base<=2259.2?0:base<=2826.65?base*.075-169.44:base<=3751.05?base*.15-381.44:base<=4664.68?base*.225-662.77:base*.275-896;document.getElementById('calc').addEventListener('click',()=>{const bruto=+bruto.value||0,deps=+deps.value||0,ad=(+vt.value||0)+(+vr.value||0)+(+saude.value||0)+(+outros.value||0),inss=inssCalc(bruto),base=Math.max(bruto-inss-deps*189.59,0),ir=Math.max(irrf(base),0),td=inss+ir+ad;liq.textContent=f(Math.max(bruto-td,0));det.textContent=`Bruto ${f(bruto)} · INSS ${f(inss)} · Base IRRF ${f(base)} · IRRF ${f(ir)} · Desc. adicionais ${f(ad)} · Total descontos ${f(td)}`});</script></BaseLayout>
