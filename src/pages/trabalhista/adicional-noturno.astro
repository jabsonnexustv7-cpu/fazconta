---
import BaseLayout from '../../layouts/BaseLayout.astro';import Breadcrumb from '../../components/Breadcrumb.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';
const title='Calculadora de Adicional Noturno'; const description='Calcule o valor estimado do adicional noturno com base em salário, jornada mensal e horas noturnas.'; const faqItems=[{question:'Qual percentual foi usado?',answer:'Esta calculadora usa 20% sobre a hora normal, regra comum da CLT urbana.'},{question:'Considera hora noturna reduzida?',answer:'Não nesta versão. O cálculo é simplificado.'},{question:'Serve para conferência de holerite?',answer:'Ajuda a conferir, mas não substitui cálculos oficiais da empresa.'},{question:'Posso alterar jornada mensal?',answer:'Sim. O padrão é 220h, mas você pode informar outro valor.'}];
---
<BaseLayout title={`${title} | FazConta`} description={description}><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Trabalhista',href:'/trabalhista'},{label:title}]} /><h1>{title}</h1><p class='lead'>{description}</p><AdSlot />
<form id='calc-form' class='calc-form'><label>Salário bruto (R$)<input name='salario' type='number' step='0.01' min='0' required/></label><label>Jornada mensal (horas)<input name='jornada' type='number' value='220' min='1' required/></label><label>Horas noturnas trabalhadas<input name='horas' type='number' step='0.01' min='0' required/></label><button class='btn' type='submit'>Calcular</button></form><div id='resultado' class='result-card'>Preencha os campos para calcular.</div><p class='help-text'><strong>Aviso:</strong> cálculo estimativo.</p><AdSlot /><h2>Como usar esta calculadora</h2><p>Informe salário, jornada e horas noturnas do período.</p><h2>Como o cálculo é feito</h2><p>Hora normal = salário ÷ jornada mensal. Adicional total = hora normal × 20% × horas noturnas.</p><h2>Exemplo prático</h2><p>Salário R$ 2.200, jornada 220h e 40 horas noturnas resultam em adicional próximo de R$ 80.</p><h2>Calculadoras relacionadas</h2><ul><li><a href='/trabalhista/horas-extras'>Horas extras</a></li><li><a href='/trabalhista/salario-liquido'>Salário líquido</a></li><li><a href='/trabalhista/horas-trabalhadas'>Horas trabalhadas</a></li></ul><p><a href='/trabalhista'>Categoria Trabalhista</a> · <a href='/blog'>Blog do FazConta</a></p><FAQSection title='FAQ do adicional noturno' items={faqItems} /></section>
<script>const form=document.getElementById('calc-form');const out=document.getElementById('resultado');const brl=v=>v.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});form.addEventListener('submit',e=>{e.preventDefault();const s=Number(form.salario.value||0),j=Number(form.jornada.value||220),h=Number(form.horas.value||0);const hora=s/j;const addHora=hora*0.2;const total=addHora*h;out.innerHTML=`<strong>Total estimado do adicional: ${brl(total)}</strong><br>Valor da hora normal: ${brl(hora)}<br>Adicional noturno por hora (20%): ${brl(addHora)}<br>Horas noturnas consideradas: ${h.toFixed(2)}h<br>Resultado estimativo para referência.`;});</script></BaseLayout>
