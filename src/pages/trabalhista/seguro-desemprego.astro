---
import BaseLayout from '../../layouts/BaseLayout.astro';import Breadcrumb from '../../components/Breadcrumb.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';
const title='Calculadora de Seguro-Desemprego'; const description='Estime valor da parcela e quantidade aproximada de parcelas do seguro-desemprego.';
const faqItems=[{question:'O cálculo é oficial?',answer:'Não. É uma estimativa simplificada para planejamento.'},{question:'Quantas parcelas posso receber?',answer:'Depende de meses trabalhados e histórico de solicitações.'},{question:'Existe teto para parcela?',answer:'Sim, o governo atualiza faixas e teto periodicamente.'},{question:'Onde confirmar valores finais?',answer:'Consulte canais oficiais do Ministério do Trabalho e Caixa.'}];
---
<BaseLayout title={`${title} | FazConta`} description={description}><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Trabalhista',href:'/trabalhista'},{label:title}]} /><h1>{title}</h1><p class='lead'>{description}</p><AdSlot />
<form id='calc-form' class='calc-form'><label>Média dos últimos 3 salários (R$)<input name='media' type='number' step='0.01' min='0' required/></label><label>Meses trabalhados<input name='meses' type='number' min='1' required/></label><label>Solicitações anteriores<input name='solicitacoes' type='number' min='0' max='10' required/></label><button class='btn' type='submit'>Calcular</button></form><div class='result-card' id='resultado'>Informe os dados para simular.</div><p class='help-text'><strong>Aviso:</strong> cálculo estimativo sujeito às regras oficiais vigentes.</p><AdSlot />
<h2>Como usar esta calculadora</h2><p>Informe a média salarial recente, tempo trabalhado e quantas vezes já solicitou o benefício.</p><h2>Como o cálculo é feito</h2><p>A parcela estimada usa faixas simplificadas e aplica teto aproximado. O número de parcelas é inferido pelo tempo trabalhado.</p><h2>Exemplo prático</h2><p>Com média de R$ 2.400 e 18 meses trabalhados, o simulador tende a indicar 4 parcelas próximas às faixas intermediárias.</p>
<h2>Calculadoras relacionadas</h2><ul><li><a href='/trabalhista/fgts'>FGTS</a></li><li><a href='/trabalhista/rescisao'>Rescisão</a></li><li><a href='/trabalhista/salario-liquido'>Salário líquido</a></li></ul><p><a href='/trabalhista'>Categoria Trabalhista</a> · <a href='/blog'>Blog do FazConta</a></p><FAQSection title='FAQ de seguro-desemprego' items={faqItems} /></section>
<script>const form=document.getElementById('calc-form');const out=document.getElementById('resultado');const brl=v=>v.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});form.addEventListener('submit',e=>{e.preventDefault();const m=Number(form.media.value||0),meses=Number(form.meses.value||0),s=Number(form.solicitacoes.value||0);let parcela=m*0.8;if(m>2112&&m<=3520)parcela=1689.6+(m-2112)*0.5;if(m>3520)parcela=2393.6;parcela=Math.min(parcela,2300);let qtd=meses>=24?5:meses>=12?4:meses>=6?3:0;if(s>=2)qtd=Math.max(3,qtd-1);out.innerHTML=`<strong>Parcela estimada: ${brl(parcela)}</strong><br>Quantidade aproximada de parcelas: ${qtd}<br>Média salarial informada: ${brl(m)}<br>Observação: confira regras oficiais atualizadas antes de solicitar.`;});</script></BaseLayout>
