---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = 'Calculadora de Seguro-Desemprego';
const description = 'Estime o valor da parcela do seguro-desemprego com base em faixas salariais.';
---
<BaseLayout title={`${title} | FazConta`} description={description}>
<section class='container section'>
<Breadcrumb items={[{label:'Início',href:'/'},{label:'Trabalhista',href:'/trabalhista'},{label:title}]} />
<h1>{title}</h1>
<p class='lead'>{description}</p>
<AdSlot />
<form id='calc-form' class='calc-form'></form>
<div class='result-card' id='resultado'>Preencha os campos para calcular.</div>
<p class='help-text'><strong>Aviso:</strong> cálculo estimativo para planejamento.</p>
<AdSlot />
<h2>Como usar esta calculadora</h2><p>Informe os campos solicitados e clique em calcular para obter uma estimativa instantânea.</p>
<h2>Como o cálculo é feito</h2><p>Utilizamos fórmula simplificada e transparente, com resultado exibido em destaque para facilitar comparação.</p>
<h2>Exemplo prático</h2><p>Use valores reais do seu cenário para entender impacto mensal e anual com segurança.</p>
<h2>Páginas relacionadas</h2><ul><li><a href='/trabalhista'>Ver categoria trabalhista</a></li><li><a href='/financeiro/cdi'>Simulador de CDI</a></li><li><a href='/blog'>Ler artigos do blog</a></li></ul>
<FAQSection title='Perguntas frequentes' items={[
{question:'O resultado é oficial?',answer:'Não. É uma estimativa para planejamento pessoal.'},
{question:'Funciona no celular?',answer:'Sim. A interface foi pensada para uso mobile.'},
{question:'Posso usar para tomar decisão financeira?',answer:'Pode usar como apoio, mas valide condições oficiais.'},
{question:'Preciso cadastrar conta?',answer:'Não. O uso é gratuito e imediato.'}
]} />
</section>
<script>
const form = document.getElementById('calc-form');
const out = document.getElementById('resultado');
form.innerHTML = `
<label>Valor 1<input name='a' type='number' step='0.01' required></label>
<label>Valor 2<input name='b' type='number' step='0.01' required></label>
<button class='btn' type='submit'>Calcular</button>`;
form.addEventListener('submit', (e) => {
 e.preventDefault();
 const a = Number(form.a.value||0), b = Number(form.b.value||0);
 let r='';
 const k='seguro';
 if(k==='fgts') r=`Depósito mensal: ${(a*0.08).toLocaleString('pt-BR',{style:'currency',currency:'BRL'})} | Estimativa anual: ${(a*0.96).toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}`;
 else if(k==='seguro'){ let p=a<=2112? a*0.8: a<=3520? 1689.6+(a-2112)*0.5:2393.6; r=`Parcela estimada: ${Math.min(p,2300).toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}`; }
 else if(k==='noturno') r=`Adicional estimado: ${(a*0.2*b).toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}`;
 else if(k==='vt') r=`Desconto máximo (6%): ${(a*0.06).toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}`;
 else if(k==='cltpj') r=`CLT: ${(a*0.75).toLocaleString('pt-BR',{style:'currency',currency:'BRL'})} | PJ líquido estimado: ${(b*0.85).toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}`;
 else if(k==='cdi'||k==='selic'||k==='poupanca'){const m=b/100/12; r=`Montante: ${(a*Math.pow(1+m,12)).toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}`;}
 else if(k==='emprestimo'){const i=b/100; const n=12; const pm=a*(i*Math.pow(1+i,n))/(Math.pow(1+i,n)-1); r=`Parcela aproximada: ${pm.toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}`;}
 else if(k==='reserva') r=`Meta de reserva: ${(a*b).toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}`;
 else if(k==='regra3') r=`Resultado proporcional: ${(b*100/(a||1)).toFixed(2)}`;
 else if(k==='idade'){const d1=new Date(form.a.value),d2=new Date(form.b.value);const diff=Math.floor((d2-d1)/86400000); r=`Diferença aproximada: ${Math.floor(diff/365)} anos`;}
 else if(k==='dias'){const d1=new Date(form.a.value),d2=new Date(form.b.value); r=`Dias entre datas: ${Math.floor((d2-d1)/86400000)}`; form.a.type='date'; form.b.type='date';}
 else if(k==='temp') r=`Conversão: C→F ${(a*9/5+32).toFixed(2)} | C→K ${(a+273.15).toFixed(2)}`;
 else if(k==='medidas') r=`m: ${a} | cm: ${(a*100)} | km: ${(a/1000)} | milhas: ${(a/1609.34).toFixed(4)}`;
 out.textContent = r;
});
</script>
</BaseLayout>
