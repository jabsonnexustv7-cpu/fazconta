---import BaseLayout from '../../layouts/BaseLayout.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';---
<BaseLayout title="Calculadora de Décimo Terceiro | FazConta" description="Calcule 13º bruto, parcelas, INSS, IRRF e valor líquido."><section class="container section calc-layout"><article class="calc-form"><h1>Décimo Terceiro</h1><AdSlot /><div class="form-grid"><label>Salário bruto<input id="s" type="number" /></label><label>Meses trabalhados<input id="m" type="number" value="12" /></label><label>Adiantamento já recebido<input id="a" type="number" value="0" /></label></div><button class="btn" id="c">Calcular</button></article><aside class="calc-result"><div class="result-card"><p class="result-title">Valor a receber em destaque</p><p class="result-value" id="r">R$ 0,00</p><p id="d" class="result-detail"></p></div><AdSlot /></aside></section><div class="container"><FAQSection items={[{question:'Primeira parcela tem desconto?',answer:'Normalmente não.'},{question:'INSS e IRRF em qual parte?',answer:'Sobre a segunda parcela.'},{question:'Adiantamento é abatido?',answer:'Sim.'},{question:'Resultado final é oficial?',answer:'Não, estimado.'}]} /></div><script>const f=n=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});c.onclick=()=>{const sal=+s.value||0,mes=+m.value||12,adi=+a.value||0,br=(sal/12)*mes,p1=br/2,inss=br*.08,ir=Math.max(br*.075-169.44,0),p2=br-p1-inss-ir,rec=p1+p2-adi;r.textContent=f(rec);d.textContent=`13º bruto ${f(br)} · 1ª parcela ${f(p1)} · INSS ${f(inss)} · IRRF ${f(ir)} · 2ª líquida ${f(p2)} · Adiantamento ${f(adi)}`}</script></BaseLayout>
