---
import BaseLayout from '../../layouts/BaseLayout.astro';import Breadcrumb from '../../components/Breadcrumb.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';
const title='Calculadora de Vale-Transporte'; const description='Descubra o desconto máximo de 6% e quanto a empresa deve complementar no vale-transporte.'; const faqItems=[{question:'O desconto pode passar de 6%?',answer:'Para VT CLT, o desconto do trabalhador é limitado a 6% do salário básico.'},{question:'E se meu gasto for menor que 6%?',answer:'O desconto tende a ser igual ao gasto real.'},{question:'A empresa sempre complementa?',answer:'Sim, quando o custo do transporte supera os 6% descontados.'},{question:'Este cálculo é mensal?',answer:'Sim, os valores são mensais.'}];
---
<BaseLayout title={`${title} | FazConta`} description={description}><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Trabalhista',href:'/trabalhista'},{label:title}]} /><h1>{title}</h1><p class='lead'>{description}</p><AdSlot />
<form id='calc-form' class='calc-form'><label>Salário bruto (R$)<input name='salario' type='number' step='0.01' min='0' required/></label><label>Gasto mensal com transporte (R$)<input name='gasto' type='number' step='0.01' min='0' required/></label><button class='btn' type='submit'>Calcular VT</button></form><div class='result-card' id='resultado'>Informe os valores para simular o vale-transporte.</div><p class='help-text'><strong>Aviso:</strong> estimativa para apoio de conferência.</p><AdSlot /><h2>Como usar esta calculadora</h2><p>Preencha salário e gasto mensal com condução.</p><h2>Como o cálculo é feito</h2><p>Desconto máximo = 6% do salário. Complemento da empresa = gasto - desconto do trabalhador (se positivo).</p><h2>Exemplo prático</h2><p>Com salário de R$ 2.000 e gasto de R$ 220, desconto máximo é R$ 120 e a empresa complementa R$ 100.</p><h2>Calculadoras relacionadas</h2><ul><li><a href='/trabalhista/salario-liquido'>Salário líquido</a></li><li><a href='/trabalhista/fgts'>FGTS</a></li><li><a href='/trabalhista/horas-extras'>Horas extras</a></li></ul><p><a href='/trabalhista'>Categoria Trabalhista</a> · <a href='/blog'>Blog do FazConta</a></p><FAQSection title='FAQ de vale-transporte' items={faqItems} /></section>
<script>const form=document.getElementById('calc-form');const out=document.getElementById('resultado');const brl=v=>v.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});form.addEventListener('submit',e=>{e.preventDefault();const s=Number(form.salario.value||0),g=Number(form.gasto.value||0);const max=s*0.06;const desc=Math.min(max,g);const comp=Math.max(g-desc,0);out.innerHTML=`<strong>Custo efetivo do trabalhador: ${brl(desc)}</strong><br>Desconto máximo (6%): ${brl(max)}<br>Complemento da empresa: ${brl(comp)}<br>Gasto mensal informado: ${brl(g)}<br>Resultado estimativo conforme regra geral da CLT.`;});</script></BaseLayout>
