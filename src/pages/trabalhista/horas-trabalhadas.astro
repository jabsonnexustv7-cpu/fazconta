<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Calculadora de Horas Trabalhadas</title>
    <meta name="description" content="Calcule horas trabalhadas online gratuitamente." />
  </head>
  <body style="font-family: Arial, sans-serif; padding:40px; max-width:900px; margin:auto;">
    <h1>Calculadora de Horas Trabalhadas</h1>

    <label>Entrada</label><br/>
    <input type="time" id="entrada" /><br/><br/>

    <label>Saída</label><br/>
    <input type="time" id="saida" /><br/><br/>

    <label>Intervalo (minutos)</label><br/>
    <input type="number" id="intervalo" value="60" /><br/><br/>

    <button onclick="calcular()">Calcular</button>

    <h2 id="resultado"></h2>

    <script>
      function calcular() {
        const entrada = document.getElementById('entrada').value;
        const saida = document.getElementById('saida').value;
        const intervalo = Number(document.getElementById('intervalo').value);

        if (!entrada || !saida) {
          alert('Preencha os horários');
          return;
        }

        const [eh, em] = entrada.split(':').map(Number);
        const [sh, sm] = saida.split(':').map(Number);

        let minutos = (sh * 60 + sm) - (eh * 60 + em);
        minutos -= intervalo;

        const horas = Math.floor(minutos / 60);
        const mins = minutos % 60;

        document.getElementById('resultado').innerText = `Total trabalhado: ${horas}h ${mins}min`;
      }
    </script>
  </body>
</html>
