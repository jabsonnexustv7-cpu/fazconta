---
import BaseLayout from '../../layouts/BaseLayout.astro'; import FAQSection from '../../components/FAQSection.astro'; import AdSlot from '../../components/AdSlot.astro';import CalculatorSEOContent from '../../components/CalculatorSEOContent.astro';
---
<BaseLayout title="Calculadora de Horas Trabalhadas | FazConta" description="Calcule horas líquidas, saldo e valor estimado por hora."><section class="container section calc-layout"><article class="calc-form"><h1>Horas Trabalhadas</h1><AdSlot /><div class="form-grid"><label>Entrada<input id="entrada" type="time" /></label><label>Saída<input id="saida" type="time" /></label><label>Intervalo (minutos)<input id="intervalo" type="number" value="60" /></label><label>Carga contratada (h)<input id="carga" type="number" value="8" step="0.5" /></label><label>Valor por hora (opcional)<input id="vh" type="number" step="0.01" /></label></div><button class="btn" id="c">Calcular</button></article><aside class="calc-result"><div class="result-card"><p class="result-title">Horas líquidas</p><p class="result-value" id="r">--</p><p class="result-detail" id="d"></p></div><AdSlot /></aside></section><CalculatorSEOContent title="Horas Trabalhadas" /><div class="container"><FAQSection items={[{question:'Passa da meia-noite?',answer:'Sim, o cálculo trata virada de dia.'},{question:'Intervalo é obrigatório?',answer:'Recomendado para precisão.'},{question:'Calcula banco de horas?',answer:'Mostra saldo positivo/negativo diário.'},{question:'Valor por hora é opcional?',answer:'Sim, só para estimar valor.'}]} /></div><script>const m=t=>{const[a,b]=t.split(':').map(Number);return a*60+b};c.onclick=()=>{if(!entrada.value||!saida.value)return;let bruto=m(saida.value)-m(entrada.value);if(bruto<0)bruto+=1440;const inter=+intervalo.value||0,liq=Math.max(bruto-inter,0),saldo=liq-((+carga.value||8)*60),val=+vh.value||0;r.textContent=`${Math.floor(liq/60)}h ${String(liq%60).padStart(2,'0')}min`;d.textContent=`Horas brutas: ${(bruto/60).toFixed(2)}h · Intervalo: ${inter}min · Saldo: ${(saldo/60).toFixed(2)}h ${val?`· Valor estimado: R$ ${((liq/60)*val).toFixed(2)}`:''}`}</script></BaseLayout>
