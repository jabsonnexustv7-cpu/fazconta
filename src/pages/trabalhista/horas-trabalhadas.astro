---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';

const faqItems = [
  { question: 'Como calcular horas de turno que passa da meia-noite?', answer: 'Quando a saída é menor que a entrada, considera-se virada de dia e soma-se 24 horas no horário de saída antes de calcular a diferença.' },
  { question: 'O intervalo é obrigatório pela CLT?', answer: 'Em geral, jornadas acima de determinados limites exigem intervalo intrajornada. A duração pode variar conforme a carga e acordos coletivos.' },
  { question: 'Horas extras começam a partir de quantas horas?', answer: 'Normalmente, o excedente da jornada contratada diária passa a ser tratado como hora extra, respeitando contrato e convenção coletiva.' },
  { question: 'O banco de horas tem prazo para compensar?', answer: 'Sim, pode haver prazo de compensação previsto em acordo individual ou coletivo. Verifique as regras aplicáveis ao seu vínculo.' }
];
---
<BaseLayout title="Calculadora de Horas Trabalhadas e Saldo Diário | FazConta" description="Calcule horas brutas, intervalo, horas líquidas, saldo do dia e valor estimado por hora com virada de meia-noite.">
  <section class="container section"><Breadcrumb items={[{ label: 'Início', href: '/' }, { label: 'Trabalhista', href: '/trabalhista' }, { label: 'Horas Trabalhadas' }]} /></section>
  <section class="container section calc-layout">
    <article class="calc-form">
      <h1>Calculadora de Horas Trabalhadas</h1>
      <p class="lead">Descubra suas horas brutas, horas líquidas e saldo diário em relação à carga contratada, incluindo turnos que passam da meia-noite.</p>
      <AdSlot />
      <div class="form-grid">
        <label>Hora de entrada<input id="horaEntrada" type="time" /></label>
        <label>Hora de saída<input id="horaSaida" type="time" /></label>
        <label>Intervalo (minutos)<input id="intervaloMinutos" type="number" min="0" step="1" value="60" /></label>
        <label>Carga horária contratada<input id="cargaContratada" type="time" value="08:00" /></label>
        <label>Valor por hora (opcional)<input id="valorHora" type="number" min="0" step="0.01" placeholder="Ex.: 25" /></label>
      </div>
      <button class="btn" id="calcularHoras" type="button">Calcular horas</button>
    </article>
    <aside class="calc-result">
      <div class="result-card" aria-live="polite">
        <p class="result-title">Horas líquidas</p>
        <p class="result-value" id="resultadoHorasLiquidas">0h 00min</p>
        <p class="result-detail" id="detalhesHoras">Preencha os horários para calcular seu saldo do dia.</p>
      </div>
      <AdSlot />
    </aside>
  </section>
  <section class="container section"><h2>Como usar esta calculadora</h2><p class="help-text">Informe o horário de entrada e saída, o intervalo em minutos e sua carga contratada do dia. Se quiser, preencha também o valor por hora para estimar o valor financeiro das horas líquidas.</p></section>
  <section class="container section"><h2>Como o cálculo é feito</h2><p class="help-text">A ferramenta converte entrada e saída para minutos. Se a saída for menor que a entrada, considera virada de meia-noite. Depois calcula horas brutas, subtrai o intervalo para obter horas líquidas e compara com a carga contratada para gerar o saldo.</p><p class="help-text">Se houver valor por hora, o cálculo multiplica esse valor pelas horas líquidas para estimar o total do dia.</p></section>
  <section class="container section"><h2>Exemplo prático</h2><p class="help-text">Exemplo: entrada às 22:00, saída às 06:00, intervalo de 60 min e carga de 08:00. O cálculo considera a virada de dia, totaliza 8h brutas, 7h líquidas e saldo de -1h.</p><p class="help-text">Aviso: este resultado é estimativo e serve como apoio para conferência.</p></section>
  <section class="container section"><h2>Links úteis</h2><ul><li><a href="/trabalhista/salario-liquido">Calculadora de salário líquido</a></li><li><a href="/trabalhista/ferias">Calculadora de férias</a></li><li><a href="/trabalhista/horas-extras">Calculadora de horas extras</a></li><li><a href="/blog">Conteúdos do blog</a></li></ul></section>
  <div class="container"><FAQSection items={faqItems} /><FAQSchema items={faqItems} /></div>
  <script>
    const toMinutesFromTime = (timeValue) => { const [hours, minutes] = timeValue.split(':').map(Number); return hours * 60 + minutes; };
    const formatMinutes = (totalMinutes) => { const safe = Math.max(totalMinutes, 0); return `${Math.floor(safe / 60)}h ${String(safe % 60).padStart(2, '0')}min`; };
    const formatCurrency = (value) => value.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    document.getElementById('calcularHoras')?.addEventListener('click', () => {
      const horaEntrada = document.getElementById('horaEntrada')?.value || '';
      const horaSaida = document.getElementById('horaSaida')?.value || '';
      const intervaloMinutos = Number(document.getElementById('intervaloMinutos')?.value) || 0;
      const cargaContratada = document.getElementById('cargaContratada')?.value || '08:00';
      const valorHora = Number(document.getElementById('valorHora')?.value) || 0;
      const resultadoHorasLiquidas = document.getElementById('resultadoHorasLiquidas');
      const detalhesHoras = document.getElementById('detalhesHoras');
      if (!horaEntrada || !horaSaida || !resultadoHorasLiquidas || !detalhesHoras) return;
      const entradaMinutos = toMinutesFromTime(horaEntrada);
      const saidaMinutos = toMinutesFromTime(horaSaida);
      const cargaContratadaMinutos = toMinutesFromTime(cargaContratada);
      let horasBrutasMinutos = saidaMinutos - entradaMinutos;
      if (horasBrutasMinutos < 0) horasBrutasMinutos += 24 * 60;
      const horasLiquidasMinutos = Math.max(horasBrutasMinutos - intervaloMinutos, 0);
      const saldoMinutos = horasLiquidasMinutos - cargaContratadaMinutos;
      const saldoSinal = saldoMinutos > 0 ? '+' : saldoMinutos < 0 ? '-' : '';
      const saldoTexto = `${saldoSinal}${formatMinutes(Math.abs(saldoMinutos))}`;
      const valorEstimado = valorHora > 0 ? (horasLiquidasMinutos / 60) * valorHora : 0;
      resultadoHorasLiquidas.textContent = formatMinutes(horasLiquidasMinutos);
      detalhesHoras.textContent = `Horas brutas: ${formatMinutes(horasBrutasMinutos)} · Intervalo: ${intervaloMinutos}min · Horas líquidas: ${formatMinutes(horasLiquidasMinutos)} · Saldo do dia: ${saldoTexto}${valorHora > 0 ? ` · Valor estimado: ${formatCurrency(valorEstimado)}` : ''}`;
      detalhesHoras.classList.remove('saldo-positivo', 'saldo-negativo', 'saldo-neutro');
      if (saldoMinutos > 0) detalhesHoras.classList.add('saldo-positivo');
      else if (saldoMinutos < 0) detalhesHoras.classList.add('saldo-negativo');
      else detalhesHoras.classList.add('saldo-neutro');
    });
  </script>
  <style>
    .saldo-positivo { color: #14804a; }
    .saldo-negativo { color: #b42318; }
    .saldo-neutro { color: #475467; }
  </style>
</BaseLayout>
