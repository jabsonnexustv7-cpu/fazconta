---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Horas Trabalhadas | FazConta">
  <section class="container section calculator-shell">
    <h1>Calculadora de Horas Trabalhadas</h1>
    <div class="form-grid">
      <label>Entrada <input id="entrada" type="time" /></label>
      <label>Saída <input id="saida" type="time" /></label>
      <label>Intervalo (minutos) <input id="intervalo" type="number" value="60" min="0" /></label>
    </div>
    <button class="btn" id="calcular">Calcular</button>
    <div class="result-card"><p class="result-title">Total trabalhado</p><p id="resultado" class="result-value">--</p></div>
  </section>
  <script>
    const btn = document.getElementById('calcular');
    btn?.addEventListener('click', () => {
      const entrada = document.getElementById('entrada').value;
      const saida = document.getElementById('saida').value;
      const intervalo = Number(document.getElementById('intervalo').value || 0);
      if (!entrada || !saida) return alert('Preencha entrada e saída.');
      const [eh, em] = entrada.split(':').map(Number);
      const [sh, sm] = saida.split(':').map(Number);
      let total = (sh * 60 + sm) - (eh * 60 + em);
      if (total < 0) total += 24 * 60;
      total -= intervalo;
      const h = Math.floor(Math.max(total, 0) / 60);
      const m = Math.max(total, 0) % 60;
      document.getElementById('resultado').textContent = `${h}h ${String(m).padStart(2, '0')}min`;
    });
  </script>
</BaseLayout>
