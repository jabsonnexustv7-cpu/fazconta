---
import BaseLayout from '../../layouts/BaseLayout.astro'; import FAQSection from '../../components/FAQSection.astro'; import AdSlot from '../../components/AdSlot.astro';
---
<BaseLayout title="Calculadora de Férias | FazConta" description="Simule férias com adicional de 1/3, abono pecuniário e descontos estimados."><section class="container section calc-layout"><article class="calc-form"><h1>Calculadora de Férias</h1><AdSlot /><div class="form-grid"><label>Salário bruto<input id="s" type="number" step="0.01" /></label><label>Dias de férias<input id="dias" type="number" value="30" /></label><label>Vender 1/3 das férias?<select id="v"><option value="nao">Não</option><option value="sim">Sim</option></select></label><label>Descontos adicionais<input id="des" type="number" value="0" step="0.01" /></label></div><button class="btn" id="b">Calcular</button></article><aside class="calc-result"><div class="result-card"><p class="result-title">Valor líquido em destaque</p><p class="result-value" id="rv">R$ 0,00</p><p class="result-detail" id="df"></p></div><AdSlot /></aside></section><div class="container"><FAQSection items={[{question:'Tem imposto em férias?',answer:'Pode ter INSS/IRRF conforme base.'},{question:'Abono entra?',answer:'Sim, quando marcado vender 1/3.'},{question:'É resultado oficial?',answer:'Não, estimativo.'},{question:'Posso alterar dias?',answer:'Sim, até 30 dias.'}]} /></div><script>const f=n=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});b.onclick=()=>{const sal=+s.value||0,d=+dias.value||30,fer=(sal/30)*d,ter=fer/3,ab=v.value==='sim'?sal/3:0,base=fer+ter,inss=base*.09,ir=Math.max(base*.075-169.44,0),adic=+des.value||0,liq=fer+ter+ab-inss-ir-adic;rv.textContent=f(liq);df.textContent=`Férias brutas ${f(fer)} · 1/3 ${f(ter)} · Abono ${f(ab)} · INSS ${f(inss)} · IRRF ${f(ir)} · Descontos ${f(adic)}`}</script></BaseLayout>
