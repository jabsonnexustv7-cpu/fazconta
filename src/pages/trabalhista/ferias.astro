---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Calculadora de Férias | FazConta">
  <section class="container section calc-layout">
    <article class="calc-form">
      <h1>Calculadora de Férias</h1>
      <p class="lead">Simule o valor de férias com adicional de 1/3 e abono pecuniário.</p>
      <div class="form-grid">
        <label>Salário bruto (R$) <input id="salario" type="number" step="0.01" min="0" /></label>
        <label>Dias de férias <input id="dias" type="number" min="1" max="30" value="30" /></label>
        <label>Abono pecuniário (dias vendidos) <input id="abono" type="number" min="0" max="10" value="0" /></label>
      </div>
      <button class="btn" id="calc-ferias">Calcular</button>
      <p class="calc-warning">Resultado estimativo para planejamento financeiro.</p>
    </article>
    <aside class="calc-result">
      <div class="result-card"><p class="result-title">Valor estimado de férias</p><p id="res-ferias" class="result-value">R$ 0,00</p><p id="det-ferias" class="result-detail"></p></div>
      <div class="related-links"><a href="/trabalhista/salario-liquido">Ver salário líquido</a><a href="/trabalhista/horas-trabalhadas">Ver horas trabalhadas</a></div>
    </aside>
  </section>
  <script>
    const fm = (n) => n.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    document.getElementById('calc-ferias')?.addEventListener('click', () => {
      const salario = Number(document.getElementById('salario').value || 0);
      const dias = Number(document.getElementById('dias').value || 30);
      const abonoDias = Number(document.getElementById('abono').value || 0);
      const proporcional = (salario / 30) * dias;
      const terco = proporcional / 3;
      const abono = (salario / 30) * abonoDias;
      const total = proporcional + terco + abono;
      document.getElementById('res-ferias').textContent = fm(total);
      document.getElementById('det-ferias').textContent = `Proporcional: ${fm(proporcional)} · 1/3: ${fm(terco)} · Abono: ${fm(abono)}`;
    });
  </script>
</BaseLayout>
