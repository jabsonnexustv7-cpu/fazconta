---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import FAQSection from '../../components/FAQSection.astro';
const cards=['fgts','hora-extra-noturna','seguro-desemprego','adicional-noturno','vale-transporte','conversao-clt-pj','custo-funcionario','horas-trabalhadas','salario-liquido','ferias','rescisao','decimo-terceiro','horas-extras'];
---
<BaseLayout title="Calculadoras Trabalhistas | FazConta" description="FGTS, seguro-desemprego, salário líquido, férias e muito mais.">
<section class="container section"><h1>Calculadoras Trabalhistas</h1><p class="lead">Simuladores para departamento pessoal e planejamento do trabalhador.</p><div class="cards-grid">{cards.map((s)=><CalculatorCard title={s.replaceAll('-',' ')} href={`/trabalhista/${s}`} description="Simulação trabalhista" badge="Trabalhista" icon="💼" />)}</div></section>
<div class="container"><FAQSection title="FAQ trabalhista" /></div>
</BaseLayout>
