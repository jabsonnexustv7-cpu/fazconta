---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
---

<BaseLayout title="Calculadoras Trabalhistas | FazConta" description="Ferramentas para cálculos de jornada, salário líquido e férias.">
  <section class="container section">
    <h1>Calculadoras Trabalhistas</h1>
    <p class="lead">Escolha uma calculadora e visualize seus valores com uma leitura clara e rápida.</p>
    <div class="cards-grid">
      <CalculatorCard icon="⏱" title="Horas Trabalhadas" description="Jornada líquida com intervalo e virada de dia." href="/trabalhista/horas-trabalhadas" badge="Jornada" />
      <CalculatorCard icon="💼" title="Salário Líquido" description="Estimativa com desconto de INSS e IRRF." href="/trabalhista/salario-liquido" badge="Salário" />
      <CalculatorCard icon="🌴" title="Férias" description="Valor das férias com adicional de 1/3." href="/trabalhista/ferias" badge="Benefício" />
    </div>
  </section>
</BaseLayout>
