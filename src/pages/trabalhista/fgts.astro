---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = 'Calculadora de FGTS';
const description = 'Calcule depósito mensal de FGTS, total acumulado no período e projeção de saldo com base no salário bruto.';
const faqItems = [
  { question: 'Qual é a alíquota padrão do FGTS?', answer: 'Na maioria dos contratos CLT, o depósito mensal é de 8% do salário bruto.' },
  { question: 'O valor calculado inclui rendimento da conta FGTS?', answer: 'Não. Esta simulação considera apenas os depósitos mensais informados.' },
  { question: 'Posso incluir saldo antigo de FGTS?', answer: 'Sim. O campo de saldo atual é opcional para projetar total acumulado.' },
  { question: 'Este cálculo substitui extrato da Caixa?', answer: 'Não. Para conferência oficial, consulte o extrato no app FGTS ou Caixa.' }
];
---
<BaseLayout title={`${title} | FazConta`} description={description}>
  <section class='container section'>
    <Breadcrumb items={[{ label: 'Início', href: '/' }, { label: 'Trabalhista', href: '/trabalhista' }, { label: title }]} />
    <h1>{title}</h1>
    <p class='lead'>{description}</p>
    <AdSlot />

    <form id='calc-form' class='calc-form'>
      <label>Salário bruto mensal (R$)<input name='salario' type='number' step='0.01' min='0' required /></label>
      <label>Meses trabalhados<input name='meses' type='number' min='1' max='1200' required /></label>
      <label>Saldo atual de FGTS (opcional)<input name='saldoAtual' type='number' step='0.01' min='0' /></label>
      <button class='btn' type='submit'>Calcular FGTS</button>
    </form>

    <div class='result-card' id='resultado'>Preencha os campos para calcular seu FGTS estimado.</div>
    <p class='help-text'><strong>Aviso:</strong> simulação estimativa para planejamento financeiro. Os valores oficiais podem variar.</p>

    <AdSlot />
    <h2>Como usar esta calculadora</h2><p>Informe salário bruto e quantidade de meses trabalhados. Se quiser projetar o saldo total, adicione também o saldo atual de FGTS.</p>
    <h2>Como o cálculo é feito</h2><p>Depósito mensal estimado = salário bruto × 8%. Total no período = depósito mensal × meses. Saldo projetado = saldo atual + total depositado no período.</p>
    <h2>Exemplo prático</h2><p>Com salário de R$ 3.000 por 12 meses, o depósito mensal é R$ 240 e o total do período é R$ 2.880. Se já houver R$ 5.000 em conta, o saldo estimado fica em R$ 7.880.</p>
    <h2>Calculadoras relacionadas</h2><ul><li><a href='/trabalhista/rescisao'>Calculadora de rescisão</a></li><li><a href='/trabalhista/decimo-terceiro'>Calculadora de décimo terceiro</a></li><li><a href='/trabalhista/salario-liquido'>Calculadora de salário líquido</a></li></ul>
    <p><a href='/trabalhista'>Ver todas as calculadoras trabalhistas</a> · <a href='/blog'>Acessar o blog do FazConta</a></p>
    <FAQSection title='FAQ de FGTS' items={faqItems} />
  </section>

  <script>
    const form = document.getElementById('calc-form');
    const out = document.getElementById('resultado');
    const brl = (v) => v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const salario = Number(form.salario.value || 0);
      const meses = Number(form.meses.value || 0);
      const saldoAtual = Number(form.saldoAtual.value || 0);
      const depositoMensal = salario * 0.08;
      const totalPeriodo = depositoMensal * meses;
      const saldoProjetado = saldoAtual + totalPeriodo;

      out.innerHTML = `<strong>Saldo estimado de FGTS: ${brl(saldoProjetado)}</strong><br>Depósito mensal: ${brl(depositoMensal)}<br>Total depositado no período: ${brl(totalPeriodo)}<br>Saldo atual informado: ${brl(saldoAtual)}<br>Resultado baseado na alíquota padrão de 8% para contratos CLT.`;
    });
  </script>
</BaseLayout>
