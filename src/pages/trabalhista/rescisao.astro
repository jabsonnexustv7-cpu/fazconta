---import BaseLayout from '../../layouts/BaseLayout.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';import CalculatorSEOContent from '../../components/CalculatorSEOContent.astro';---
<BaseLayout title="Calculadora de Rescisão | FazConta" description="Estime saldo, férias proporcionais, 13º proporcional, FGTS e multa."><section class="container section calc-layout"><article class="calc-form"><h1>Calculadora de Rescisão</h1><AdSlot /><div class="form-grid"><label>Salário bruto<input id="s" type="number" /></label><label>Data de admissão<input id="a" type="date" /></label><label>Data de demissão<input id="d" type="date" /></label><label>Tipo<select id="t"><option>sem justa causa</option><option>pedido de demissão</option><option>acordo mútuo</option></select></label><label>Aviso<select id="av"><option>trabalhado</option><option>indenizado</option><option>dispensado</option></select></label></div><button class="btn" id="c">Calcular</button></article><aside class="calc-result"><div class="result-card"><p class="result-title">Total líquido estimado</p><p class="result-value" id="r">R$ 0,00</p><p id="det" class="result-detail"></p></div><AdSlot /></aside></section><CalculatorSEOContent title="Rescisao" /><div class="container"><FAQSection items={[{question:'Inclui FGTS?',answer:'Sim, estimativa de depósito e multa.'},{question:'Tipo altera multa?',answer:'Sim.'},{question:'Tem descontos?',answer:'Aplicado valor estimado simples.'},{question:'Serve para homologação?',answer:'Apenas referência inicial.'}]} /></div><script>const f=n=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});c.onclick=()=>{const sal=+s.value||0;const ad=new Date(a.value),de=new Date(d.value);const meses=Math.max((de.getFullYear()-ad.getFullYear())*12+(de.getMonth()-ad.getMonth()),1);const saldo=sal/30*de.getDate(),dec=(sal/12)*(de.getMonth()+1),fer=(sal/12)*meses,ter=fer/3,fgts=(sal*0.08)*meses,multa=t.value==='sem justa causa'?fgts*0.4:t.value==='acordo mútuo'?fgts*0.2:0,aviso=av.value==='indenizado'?sal:0,desc=(saldo+dec)*0.08,total=saldo+dec+fer+ter+fgts+multa+aviso-desc;r.textContent=f(total);det.textContent=`Saldo ${f(saldo)} · 13º ${f(dec)} · Férias prop. ${f(fer)} · 1/3 ${f(ter)} · FGTS ${f(fgts)} · Multa ${f(multa)} · Aviso ${f(aviso)} · Descontos ${f(desc)}`}</script></BaseLayout>
