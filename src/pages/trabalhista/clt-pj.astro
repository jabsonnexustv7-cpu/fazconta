---
import BaseLayout from '../../layouts/BaseLayout.astro';import Breadcrumb from '../../components/Breadcrumb.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';
const title='Calculadora CLT x PJ'; const description='Compare líquido estimado entre proposta CLT e PJ, incluindo benefícios e impostos.';
---
<BaseLayout title={`${title} | FazConta`} description={description}><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Trabalhista',href:'/trabalhista'},{label:title}]} /><h1>{title}</h1><p class='lead'>{description}</p><AdSlot />
<form id='calc-form' class='calc-form'><label>Salário CLT bruto (R$)<input name='clt' type='number' step='0.01' required/></label><label>Valor mensal PJ (R$)<input name='pj' type='number' step='0.01' required/></label><label>Benefícios CLT mensais (opcional)<input name='benef' type='number' step='0.01'/></label><label>Impostos PJ estimados (%)<input name='imp' type='number' step='0.01' value='13' required/></label><button class='btn' type='submit'>Comparar</button></form><div id='resultado' class='result-card'>Preencha os dados.</div><p class='help-text'><strong>Aviso:</strong> estimativa simplificada.</p><AdSlot /><h2>Como usar esta calculadora</h2><p>Informe valores CLT e PJ e ajuste o percentual de impostos PJ.</p><h2>Como o cálculo é feito</h2><p>Líquido CLT estimado = CLT × 0,8 + benefícios. Líquido PJ = PJ × (1 - impostos).</p><h2>Exemplo prático</h2><p>CLT R$ 5.000 com R$ 800 benefícios pode superar PJ de R$ 6.000 com imposto alto.</p><h2>Calculadoras relacionadas</h2><ul><li><a href='/trabalhista/salario-liquido'>Salário líquido</a></li><li><a href='/trabalhista/fgts'>FGTS</a></li><li><a href='/trabalhista/rescisao'>Rescisão</a></li></ul><p><a href='/trabalhista'>Categoria Trabalhista</a> · <a href='/blog'>Blog</a></p><FAQSection title='FAQ CLT x PJ' items={[{question:'Este comparativo é definitivo?',answer:'Não, é uma referência rápida.'},{question:'Benefícios entram na conta?',answer:'Sim, no campo opcional de CLT.'},{question:'Impostos PJ variam?',answer:'Sim, conforme regime e custos.'},{question:'Inclui riscos trabalhistas?',answer:'Não, mostramos observação qualitativa.'}]} /></section>
<script>const f=document.getElementById('calc-form'),o=document.getElementById('resultado'),brl=v=>v.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});f.addEventListener('submit',e=>{e.preventDefault();const clt=+f.clt.value||0,pj=+f.pj.value||0,b=+f.benef.value||0,imp=(+f.imp.value||0)/100;const lclt=clt*0.8+b,lpj=pj*(1-imp),dif=lpj-lclt;o.innerHTML=`<strong>Diferença mensal: ${brl(dif)}</strong><br>Líquido CLT estimado: ${brl(lclt)}<br>Líquido PJ estimado: ${brl(lpj)}<br>Observação: compare também estabilidade, férias, 13º e riscos contratuais.`;});</script></BaseLayout>
