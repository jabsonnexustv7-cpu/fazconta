---import BaseLayout from '../../layouts/BaseLayout.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';---
<BaseLayout title="Calculadora de Horas Extras | FazConta" description="Calcule horas extras 50%, 100% e noturnas."><section class="container section calc-layout"><article class="calc-form"><h1>Horas Extras</h1><AdSlot /><div class="form-grid"><label>Salário bruto<input id="s" type="number" /></label><label>HE 50%<input id="h50" type="number" value="0" /></label><label>HE 100%<input id="h100" type="number" value="0" /></label><label>HE noturna 50%<input id="hn" type="number" value="0" /></label></div><button class="btn" id="c">Calcular</button></article><aside class="calc-result"><div class="result-card"><p class="result-title">Total a receber</p><p class="result-value" id="r">R$ 0,00</p><p class="result-detail" id="d"></p></div><AdSlot /></aside></section><script>const f=n=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});c.onclick=()=>{const vh=(+s.value||0)/220,v50=vh*1.5*(+h50.value||0),v100=vh*2*(+h100.value||0),vn=vh*1.7*(+hn.value||0),t=v50+v100+vn;r.textContent=f(t);d.textContent=`Hora normal ${f(vh)} · HE 50% ${f(v50)} · HE 100% ${f(v100)} · HE noturna ${f(vn)}`}</script><div class="container"><AdSlot /><FAQSection items={[{question:'Base de 220h?',answer:'Sim, convenção comum.'},{question:'Noturna aqui é fixa?',answer:'Sim, fator estimado 1,7.'},{question:'Inclui DSR?',answer:'Não.'},{question:'É valor bruto?',answer:'Sim.'}]} /></div></BaseLayout>
