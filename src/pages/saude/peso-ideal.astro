---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
const title='Calculadora de Peso Ideal por Altura | FazConta';
const description='Veja a faixa estimada de peso saudável por altura usando IMC de referência entre 18,5 e 24,9.';
const faqItems=[{question:'Peso ideal é um número fixo?',answer:'Não. O mais adequado é pensar em faixa estimativa, não em valor único.'},{question:'A composição corporal muda a interpretação?',answer:'Sim. Massa muscular, estrutura óssea e contexto clínico influenciam bastante.'},{question:'Essa faixa vale para todos?',answer:'É referência geral para adultos. Gestantes, adolescentes e idosos podem precisar de critérios adicionais.'},{question:'Quando procurar avaliação profissional?',answer:'Ao planejar mudanças de peso, dieta ou treino, ou em caso de sintomas e doenças prévias.'}];
---
<BaseLayout title={title} description={description}><section class="container section"><Breadcrumb items={[{label:'Home',href:'/'},{label:'Saúde',href:'/saude'},{label:'Peso ideal'}]} /><h1>Calculadora de peso ideal</h1><p class="lead">Estime uma faixa de peso considerada saudável para sua altura.</p><p>Esta ferramenta usa IMC de referência entre 18,5 e 24,9 para calcular um intervalo aproximado. Isso não representa diagnóstico nem meta obrigatória.</p><AdSlot /><div class="calc-layout"><form class="calc-form" id="peso-ideal-form"><h2>Dados para cálculo</h2><div class="form-grid"><label>Altura (cm)<input type="number" name="altura" min="30" step="0.1" required/></label><label>Sexo<select name="sexo" required><option value="feminino">Feminino</option><option value="masculino">Masculino</option></select></label></div><button class="btn" type="submit">Calcular faixa</button></form><div class="calc-result"><h2 class="result-title">Resultado</h2><p class="result-value" id="peso-faixa">--</p><p class="result-detail">Faixa aproximada com base no IMC de referência.</p></div></div><p><strong>Aviso:</strong> cálculo estimativo. Para metas personalizadas, procure nutricionista ou médico.</p><h2>Como usar esta calculadora</h2><ul><li>Informe altura em centímetros.</li><li>Selecione o sexo para fins de registro no cálculo.</li><li>Use o intervalo como referência inicial e acompanhe evolução.</li></ul><h2>Como o cálculo é feito</h2><p class="help-text">Convertendo a altura para metros, calculamos: peso mínimo = 18,5 × altura² e peso máximo = 24,9 × altura².</p><h2>Exemplo prático</h2><p class="help-text">Para 170 cm, a faixa estimada fica aproximadamente entre 53,5 kg e 72,0 kg.</p><h2>Calculadoras relacionadas</h2><ul><li><a href="/saude/imc">IMC</a></li><li><a href="/saude/tmb">TMB</a></li><li><a href="/saude/calorias-diarias">Calorias diárias</a></li></ul><p><a href="/saude">Voltar para categoria Saúde</a> · <a href="/blog">Ir para o blog</a></p><FAQSection title="FAQ sobre peso ideal" items={faqItems}/><FAQSchema items={faqItems}/></section><script>document.getElementById('peso-ideal-form')?.addEventListener('submit',(e)=>{e.preventDefault();const d=new FormData(e.currentTarget);const altura=Number(d.get('altura'))/100;const min=18.5*altura*altura;const max=24.9*altura*altura;document.getElementById('peso-faixa').textContent=`${min.toFixed(1).replace('.',',')} kg a ${max.toFixed(1).replace('.',',')} kg`;});</script></BaseLayout>
