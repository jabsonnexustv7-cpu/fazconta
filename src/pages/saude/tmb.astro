---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';

const title = 'Calculadora de TMB (Mifflin-St Jeor) | FazConta';
const description = 'Estime sua Taxa Metabólica Basal com fórmula de Mifflin-St Jeor. Resultado informativo para planejamento, sem diagnóstico.';
const faqItems = [
  { question: 'TMB é igual ao total de calorias do dia?', answer: 'Não. TMB representa gasto em repouso. O gasto diário total depende do nível de atividade e rotina.' },
  { question: 'A fórmula vale para todos?', answer: 'Ela é uma estimativa para adultos e pode variar conforme composição corporal, condições clínicas e outros fatores.' },
  { question: 'Posso usar para emagrecimento?', answer: 'Pode ajudar no planejamento inicial, mas metas de peso devem ser definidas com orientação profissional.' },
  { question: 'Com que frequência devo recalcular?', answer: 'Sempre que houver mudança relevante de peso, rotina de atividade ou objetivo.' }
];
---
<BaseLayout title={title} description={description}>
<section class="container section">
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Saúde', href: '/saude' }, { label: 'TMB' }]} />
  <h1>Calculadora de TMB</h1>
  <p class="lead">Calcule sua taxa metabólica basal estimada com base em sexo, idade, peso e altura.</p>
  <p>A TMB indica quanta energia seu corpo gasta em repouso para manter funções vitais. É uma estimativa útil para planejamento nutricional, sem substituir avaliação individual.</p>
  <AdSlot />
  <div class="calc-layout">
    <form class="calc-form" id="tmb-form">
      <h2>Dados para cálculo</h2>
      <div class="form-grid">
        <label>Sexo
          <select name="sexo" required>
            <option value="masculino">Masculino</option><option value="feminino">Feminino</option>
          </select>
        </label>
        <label>Idade (anos)<input type="number" name="idade" min="10" max="120" required /></label>
        <label>Peso (kg)<input type="number" name="peso" step="0.1" min="1" required /></label>
        <label>Altura (cm)<input type="number" name="altura" step="0.1" min="30" required /></label>
      </div>
      <button class="btn" type="submit">Calcular TMB</button>
    </form>
    <div class="calc-result"><h2 class="result-title">Resultado</h2><p class="result-value" id="tmb-valor">--</p><p class="result-detail">Taxa metabólica basal estimada em kcal/dia.</p></div>
  </div>
  <p><strong>Aviso:</strong> cálculo estimativo para educação e planejamento. Procure profissional de saúde para decisões individualizadas.</p>
  <h2>Como usar esta calculadora</h2><ul><li>Informe seus dados atuais.</li><li>Use a TMB como base de comparação.</li><li>Combine com cálculo de calorias diárias para metas práticas.</li></ul>
  <h2>Como o cálculo é feito</h2><p class="help-text">Fórmula de Mifflin-St Jeor: homens = 10 × peso + 6,25 × altura − 5 × idade + 5; mulheres = 10 × peso + 6,25 × altura − 5 × idade − 161.</p>
  <h2>Exemplo prático</h2><p class="help-text">Mulher, 30 anos, 65 kg e 165 cm: TMB ≈ 1.370 kcal/dia (estimativa).</p>
  <h2>Calculadoras relacionadas</h2><ul><li><a href="/saude/calorias-diarias">Calorias diárias</a></li><li><a href="/saude/agua-diaria">Água diária</a></li><li><a href="/saude/imc">IMC</a></li></ul>
  <p><a href="/saude">Voltar para categoria Saúde</a> · <a href="/blog">Ir para o blog</a></p>
  <FAQSection title="FAQ sobre TMB" items={faqItems} /><FAQSchema items={faqItems} />
</section>
<script>
const form = document.getElementById('tmb-form');
form?.addEventListener('submit', (e) => { e.preventDefault(); const d=new FormData(form); const sexo=d.get('sexo'); const idade=Number(d.get('idade')); const peso=Number(d.get('peso')); const altura=Number(d.get('altura')); const base=(10*peso)+(6.25*altura)-(5*idade); const tmb=sexo==='masculino'?base+5:base-161; document.getElementById('tmb-valor').textContent=`${Math.round(tmb).toLocaleString('pt-BR')} kcal/dia`;});
</script>
</BaseLayout>
