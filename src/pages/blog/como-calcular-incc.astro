const faqItems=[{question:'INCC e IPCA são iguais?',answer:'Não. O INCC mede custos da construção civil; o IPCA mede inflação ao consumidor.'},{question:'Contrato pode usar outro índice?',answer:'Sim. Cada contrato define regra de reajuste e periodicidade.'},{question:'Correção mensal é igual ao acumulado dividido por meses?',answer:'Não necessariamente; o correto é usar taxa equivalente composta.'},{question:'A calculadora substitui análise contratual?',answer:'Não. Ela apoia estimativa; cláusulas contratuais prevalecem.'}];
