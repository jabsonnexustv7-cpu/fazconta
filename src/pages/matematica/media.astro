---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
const faqItems=[{question:'Como separar os números?',answer:'Digite a lista com vírgulas, por exemplo: 7, 8, 9.'},{question:'Posso usar número decimal?',answer:'Sim, valores como 7.5 e 8.25 são aceitos.'},{question:'A média ponderada entra aqui?',answer:'Não. Esta página calcula apenas média aritmética simples.'},{question:'O resultado é arredondado?',answer:'Mostramos até 4 casas decimais para manter leitura clara.'}];
---
<BaseLayout title='Calculadora de Média | FazConta' description='Calcule média aritmética com lista de números, soma total e quantidade de itens.'>
<section class='container section'>
<Breadcrumb items={[{label:'Home',href:'/'},{label:'Matemática',href:'/matematica'},{label:'Média'}]} />
<h1>Calculadora de média aritmética</h1><p class='lead'>Informe uma lista de números separados por vírgula e veja média, soma e quantidade.</p><AdSlot />
<div class='calc-layout'><form class='calc-form' id='media-form'><label>Lista de números (separados por vírgula)<input name='lista' placeholder='Ex.: 7, 8, 9' required/></label><button class='btn' type='submit'>Calcular média</button></form><div class='calc-result'><h2 class='result-title'>Resultado</h2><p class='result-value' id='media-valor'>--</p><p class='result-detail' id='media-detalhe'>Preencha a lista para calcular.</p></div></div>
<h2>Como usar esta calculadora</h2><p>Digite os números na ordem que quiser. Exemplo prático: 7, 8, 9. A média será 8, com soma 24 e quantidade 3.</p>
<h2>Calculadoras relacionadas</h2><ul><li><a href='/matematica/fracoes'>Frações</a></li><li><a href='/matematica/mdc-mmc'>MDC e MMC</a></li><li><a href='/utilidades/regra-de-tres'>Regra de três</a></li></ul>
<p><a href='/matematica'>Voltar para Matemática</a> · <a href='/blog'>Ir para o blog</a></p>
<AdSlot /><FAQSection title='FAQ de média aritmética' items={faqItems}/><FAQSchema items={faqItems}/>
</section>
<script>document.getElementById('media-form')?.addEventListener('submit',(e)=>{e.preventDefault();const raw=e.currentTarget.lista.value||'';const nums=raw.split(',').map(v=>Number(v.trim())).filter(v=>Number.isFinite(v));if(!nums.length){document.getElementById('media-valor').textContent='Lista inválida';document.getElementById('media-detalhe').textContent='Digite pelo menos um número válido.';return;}const soma=nums.reduce((a,b)=>a+b,0);const media=soma/nums.length;document.getElementById('media-valor').textContent=`Média: ${media.toLocaleString('pt-BR',{maximumFractionDigits:4})}`;document.getElementById('media-detalhe').textContent=`Quantidade: ${nums.length} | Soma: ${soma.toLocaleString('pt-BR',{maximumFractionDigits:4})}`;});</script>
</BaseLayout>