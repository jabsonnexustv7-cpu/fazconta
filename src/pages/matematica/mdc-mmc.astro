---
import BaseLayout from '../../layouts/BaseLayout.astro';import Breadcrumb from '../../components/Breadcrumb.astro';import AdSlot from '../../components/AdSlot.astro';import FAQSection from '../../components/FAQSection.astro';import FAQSchema from '../../components/FAQSchema.astro';
const faqItems=[{question:'Para que serve o MDC?',answer:'Para simplificar frações e dividir quantidades em partes iguais.'},{question:'Para que serve o MMC?',answer:'Para somar/subtrair frações e alinhar ciclos.'},{question:'Só aceita inteiros?',answer:'Sim, este cálculo trabalha com números inteiros.'},{question:'Pode ser número negativo?',answer:'Consideramos o valor absoluto no cálculo.'}];
---
<BaseLayout title='MDC e MMC | FazConta' description='Calcule rapidamente o MDC e MMC de dois números inteiros.'><section class='container section'><Breadcrumb items={[{label:'Home',href:'/'},{label:'Matemática',href:'/matematica'},{label:'MDC e MMC'}]} /><h1>Calculadora de MDC e MMC</h1><AdSlot /><div class='calc-layout'><form class='calc-form' id='mdc-form'><div class='form-grid'><label>Número 1<input name='a' type='number' required/></label><label>Número 2<input name='b' type='number' required/></label></div><button class='btn'>Calcular</button></form><div class='calc-result'><h2 class='result-title'>Resultado</h2><p class='result-value' id='mdcvalor'>--</p><p class='result-detail' id='mmcvalor'>--</p></div></div><p class='help-text'>Exemplo: para 12 e 18, o MDC é 6 e o MMC é 36.</p><FAQSection title='FAQ de MDC e MMC' items={faqItems}/><FAQSchema items={faqItems}/></section><script>const gcd=(x,y)=>{x=Math.abs(x);y=Math.abs(y);while(y){[x,y]=[y,x%y]}return x||1};document.getElementById('mdc-form')?.addEventListener('submit',(e)=>{e.preventDefault();const a=Number(e.currentTarget.a.value),b=Number(e.currentTarget.b.value);const m=gcd(a,b);const mmc=Math.abs(a*b)/(m||1);document.getElementById('mdcvalor').textContent=`MDC: ${m}`;document.getElementById('mmcvalor').textContent=`MMC: ${mmc}`;});</script></BaseLayout>
