---
import BaseLayout from '../../layouts/BaseLayout.astro';import Breadcrumb from '../../components/Breadcrumb.astro';import AdSlot from '../../components/AdSlot.astro';import FAQSection from '../../components/FAQSection.astro';import FAQSchema from '../../components/FAQSchema.astro';
const faqItems=[{question:'Como simplifica fração?',answer:'Dividimos numerador e denominador pelo MDC entre eles.'},{question:'Pode dividir por fração?',answer:'Sim, multiplicando pela inversa da segunda fração.'},{question:'E se denominador for zero?',answer:'A operação é inválida e mostramos aviso.'},{question:'Mostra decimal também?',answer:'Sim, exibimos fração simplificada e valor decimal.'}];
---
<BaseLayout title='Calculadora de Frações | FazConta' description='Some, subtraia, multiplique e divida frações com simplificação automática.'><section class='container section'><Breadcrumb items={[{label:'Home',href:'/'},{label:'Matemática',href:'/matematica'},{label:'Frações'}]} /><h1>Calculadora de frações</h1><p class='lead'>Resolva operações com frações e veja o resultado simplificado e em decimal.</p><AdSlot />
<div class='calc-layout'><form class='calc-form' id='fracoes-form'><div class='form-grid'><label>Numerador 1<input name='n1' type='number' required /></label><label>Denominador 1<input name='d1' type='number' required /></label><label>Operação<select name='op'><option value='soma'>Soma</option><option value='sub'>Subtração</option><option value='mult'>Multiplicação</option><option value='div'>Divisão</option></select></label><label>Numerador 2<input name='n2' type='number' required /></label><label>Denominador 2<input name='d2' type='number' required /></label></div><button class='btn' type='submit'>Calcular fração</button></form><div class='calc-result'><h2 class='result-title'>Resultado</h2><p class='result-value' id='fracao'>--</p><p class='result-detail' id='decimal'>--</p></div></div><p><a href='/matematica/juros-simples'>Juros simples</a> · <a href='/matematica/mdc-mmc'>MDC e MMC</a> · <a href='/blog/como-calcular-regra-de-tres'>Guia de regra de três</a></p><AdSlot /><FAQSection title='FAQ de frações' items={faqItems}/><FAQSchema items={faqItems}/></section>
<script>const m=(a,b)=>{a=Math.abs(a);b=Math.abs(b);while(b){[a,b]=[b,a%b]}return a||1};document.getElementById('fracoes-form')?.addEventListener('submit',(e)=>{e.preventDefault();const f=e.currentTarget;let n1=Number(f.n1.value),d1=Number(f.d1.value),n2=Number(f.n2.value),d2=Number(f.d2.value);if(!d1||!d2){fracao.textContent='Denominador não pode ser zero';decimal.textContent='';return;}let n=0,d=1;if(f.op.value==='soma'){n=n1*d2+n2*d1;d=d1*d2}else if(f.op.value==='sub'){n=n1*d2-n2*d1;d=d1*d2}else if(f.op.value==='mult'){n=n1*n2;d=d1*d2}else{if(!n2){fracao.textContent='Divisão inválida';decimal.textContent='';return;}n=n1*d2;d=d1*n2}if(d<0){n=-n;d=-d}const g=m(n,d);n/=g;d/=g;fracao.textContent=`${n}/${d}`;decimal.textContent=`Decimal: ${(n/d).toLocaleString('pt-BR',{maximumFractionDigits:6})}`;});</script></BaseLayout>
