---import BaseLayout from '../../layouts/BaseLayout.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';import CalculatorSEOContent from '../../components/CalculatorSEOContent.astro';---
<BaseLayout title="Calculadora de Porcentagem | FazConta" description="Resolva porcentagens em 3 modos: X% de Y, X é % de Y e variação percentual."><section class="container section calc-layout"><article class="calc-form"><h1>Calculadora de Porcentagem</h1><AdSlot /><div class="form-grid"><label>Modo<select id="m"><option value="1">X% de Y</option><option value="2">X é qual % de Y</option><option value="3">Variação de X para Y</option></select></label><label>X<input id="x" type="number" step="0.01" /></label><label>Y<input id="y" type="number" step="0.01" /></label></div><button class="btn" id="c">Calcular</button></article><aside class="calc-result"><div class="result-card"><p class="result-title">Valor calculado</p><p class="result-value" id="r">0</p><p id="d" class="result-detail"></p></div><AdSlot /></aside></section><script>c.onclick=()=>{const a=+x.value||0,b=+y.value||0;let v=0,e='';if(m.value==='1'){v=(a/100)*b;e=`${a}% de ${b}`;}if(m.value==='2'){v=b? (a/b)*100:0;e=`${a} representa ${v.toFixed(2)}% de ${b}`;}if(m.value==='3'){v=a?((b-a)/a)*100:0;e=`Variação percentual de ${a} para ${b}`;}r.textContent=v.toFixed(2)+(m.value==='1'?'':'%');d.textContent=e;}</script><CalculatorSEOContent title="Porcentagem" /><div class="container"><FAQSection items={[{question:'Tem três modos?',answer:'Sim.'},{question:'Aceita decimais?',answer:'Sim.'},{question:'Mostra explicação?',answer:'Sim, curta.'},{question:'É instantâneo?',answer:'Sim, ao clicar calcular.'}]} /></div></BaseLayout>
