---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import AdSlot from '../../components/AdSlot.astro';
const faqItems=[{question:'O resultado é oficial?',answer:'Não. É uma simulação para planejamento.'},{question:'Posso usar no celular?',answer:'Sim, a calculadora funciona em dispositivos móveis.'},{question:'Este cálculo substitui análise profissional?',answer:'Não. Use como apoio e valide condições reais.'},{question:'Os valores têm arredondamento?',answer:'Sim, para facilitar leitura em reais e percentuais.'}];
---
<BaseLayout title="Calculadora de Porcentagem | FazConta" description="Calcule aumento, desconto e percentual."><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Utilidades',href:'/utilidades'},{label:'Calculadora de Porcentagem'}]} /><h1>Calculadora de Porcentagem</h1><p class='lead'>Calcule aumento, desconto e percentual.</p><p class='help-text'><strong>Aviso:</strong> cálculo estimativo para planejamento.</p><AdSlot /><div class='form-grid'><label>Valor base<input id='v' type='number' step='0.01' value='1000'></label><label>Percentual (%)<input id='p' type='number' step='0.01' value='10'></label></div><button class='btn' id='calc'>Calcular</button><div class='result-card'><p class='result-title'>Resultado</p><p class='result-value' id='res'>-</p><p class='result-detail' id='det'></p></div><h2>Como usar esta calculadora</h2><p>Preencha os campos com seus valores reais e clique em calcular.</p><h2>Como o cálculo é feito</h2><p>Aplicamos fórmula financeira/matemática padrão com exibição do breakdown.</p><h2>Exemplo prático</h2><p>Teste com valores próximos da sua realidade para comparar cenários.</p><h2>Calculadoras relacionadas</h2><ul><li><a href='/utilidades/regra-de-tres'>regra de tres</a></li><li><a href='/financeiro/juros-compostos'>juros compostos</a></li><li><a href='/utilidades/imc'>imc</a></li><li><a href='/utilidades'>Ver categoria utilidades</a></li><li><a href='/blog'>Ver blog</a></li></ul><FAQSection items={faqItems} /><FAQSchema items={faqItems} /></section><script>const f=n=>n.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});calc.onclick=()=>{const b=+v.value||0,pc=(+p.value||0)/100;const delta=b*pc;res.textContent=f(delta);det.textContent=`${p.value}% de ${f(b)} · Com aumento ${f(b+delta)} · Com desconto ${f(b-delta)}`;};</script></BaseLayout>