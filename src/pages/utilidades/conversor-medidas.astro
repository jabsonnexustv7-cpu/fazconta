---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import AdSlot from '../../components/AdSlot.astro';
const faqItems=[{question:'O resultado é oficial?',answer:'Não. É uma simulação para planejamento.'},{question:'Posso usar no celular?',answer:'Sim, a calculadora funciona em dispositivos móveis.'},{question:'Este cálculo substitui análise profissional?',answer:'Não. Use como apoio e valide condições reais.'},{question:'Os valores têm arredondamento?',answer:'Sim, para facilitar leitura em reais e percentuais.'}];
---
<BaseLayout title="Conversor de Medidas | FazConta" description="Converta metros para cm, km e milhas."><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Utilidades',href:'/utilidades'},{label:'Conversor de Medidas'}]} /><h1>Conversor de Medidas</h1><p class='lead'>Converta metros para cm, km e milhas.</p><p class='help-text'><strong>Aviso:</strong> cálculo estimativo para planejamento.</p><AdSlot /><div class='form-grid'><label>Distância em metros<input id='m' type='number' step='0.01' value='1000'></label></div><button class='btn' id='calc'>Calcular</button><div class='result-card'><p class='result-title'>Resultado</p><p class='result-value' id='res'>-</p><p class='result-detail' id='det'></p></div><h2>Como usar esta calculadora</h2><p>Preencha os campos com seus valores reais e clique em calcular.</p><h2>Como o cálculo é feito</h2><p>Aplicamos fórmula financeira/matemática padrão com exibição do breakdown.</p><h2>Exemplo prático</h2><p>Teste com valores próximos da sua realidade para comparar cenários.</p><h2>Calculadoras relacionadas</h2><ul><li><a href='/utilidades/conversor-temperatura'>conversor temperatura</a></li><li><a href='/utilidades/regra-de-tres'>regra de tres</a></li><li><a href='/utilidades/dias-entre-datas'>dias entre datas</a></li><li><a href='/utilidades'>Ver categoria utilidades</a></li><li><a href='/blog'>Ver blog</a></li></ul><FAQSection items={faqItems} /><FAQSchema items={faqItems} /></section><script>calc.onclick=()=>{const v=+m.value||0;res.textContent=`${(v/1000).toFixed(3)} km`;det.textContent=`${v} m · ${(v*100).toFixed(0)} cm · ${(v/1609.34).toFixed(4)} milhas`;};</script></BaseLayout>