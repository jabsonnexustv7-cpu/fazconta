---
import BaseLayout from '../../layouts/BaseLayout.astro';import CalculatorCard from '../../components/CalculatorCard.astro';import FAQSection from '../../components/FAQSection.astro';
const cards=['regra-de-tres','conversor-de-temperatura','conversor-de-medidas','conversor-de-bytes','dias-entre-datas','idade-exata','cronometro','contador-regressivo'];
---
<BaseLayout title="Calculadoras de Utilidades | FazConta" description="Conversores e utilidades para o dia a dia."><section class="container section"><h1>Calculadoras de Utilidades</h1><p class="lead">Ferramentas rápidas para tarefas cotidianas.</p><div class="cards-grid">{cards.map((s)=><CalculatorCard title={s.replaceAll('-',' ')} href={`/utilidades/${s}`} description="Calculadora utilitária" badge="Utilidades" icon="🛠" />)}</div></section><div class="container"><FAQSection title="FAQ utilidades" /></div></BaseLayout>
