---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
const cards=['regra-de-tres','idade-exata','dias-entre-datas','conversor-temperatura','conversor-medidas','imc','porcentagem'];
const faqItems=[{question:'As simulações são oficiais?',answer:'Não. São estimativas para utilidades.'},{question:'Posso comparar cenários?',answer:'Sim, altere taxa, prazo e aportes para comparar.'},{question:'Tem custos de banco inclusos?',answer:'Nem sempre. Verifique tarifas e impostos no contrato.'},{question:'Substitui consultoria?',answer:'Não. Use como apoio para decisão.'}];
---
<BaseLayout title='Utilidades | FazConta' description='Calculadoras de utilidades para cotidiano, conversões e rotinas.'><section class='container section'><h1>Calculadoras de utilidades do FazConta</h1><p class='lead'>Planeje investimentos, dívidas e reserva com respostas rápidas para o cotidiano.</p><h2>Todas as calculadoras</h2><div class='cards-grid'>{cards.map((s)=><CalculatorCard title={s.replaceAll('-',' ')} href={`/utilidades/${s}`} description='Calculadora utilitária específica' badge='Utilidades' icon='utilidades' />)}</div><h2>Mais acessadas</h2><ul><li><a href='/utilidades/regra-de-tres'>Regra de três</a></li><li><a href='/utilidades/dias-entre-datas'>Dias entre datas</a></li><li><a href='/utilidades/porcentagem'>Porcentagem</a></li></ul><p><a href='/blog'>Ver conteúdos no blog</a></p><FAQSection items={faqItems} /><FAQSchema items={faqItems} /></section></BaseLayout>