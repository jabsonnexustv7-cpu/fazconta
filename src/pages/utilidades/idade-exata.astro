---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import AdSlot from '../../components/AdSlot.astro';
const faqItems=[{question:'O resultado é oficial?',answer:'Não. É uma simulação para planejamento.'},{question:'Posso usar no celular?',answer:'Sim, a calculadora funciona em dispositivos móveis.'},{question:'Este cálculo substitui análise profissional?',answer:'Não. Use como apoio e valide condições reais.'},{question:'Os valores têm arredondamento?',answer:'Sim, para facilitar leitura em reais e percentuais.'}];
---
<BaseLayout title="Calculadora de Idade Exata | FazConta" description="Calcule idade em anos, meses e dias."><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Utilidades',href:'/utilidades'},{label:'Calculadora de Idade Exata'}]} /><h1>Calculadora de Idade Exata</h1><p class='lead'>Calcule idade em anos, meses e dias.</p><p class='help-text'><strong>Aviso:</strong> cálculo estimativo para planejamento.</p><AdSlot /><div class='form-grid'><label>Data de nascimento<input id='dn' type='date' step='1' value=''></label><label>Data de referência<input id='dr' type='date' step='1' value=''></label></div><button class='btn' id='calc'>Calcular</button><div class='result-card'><p class='result-title'>Resultado</p><p class='result-value' id='res'>-</p><p class='result-detail' id='det'></p></div><h2>Como usar esta calculadora</h2><p>Preencha os campos com seus valores reais e clique em calcular.</p><h2>Como o cálculo é feito</h2><p>Aplicamos fórmula financeira/matemática padrão com exibição do breakdown.</p><h2>Exemplo prático</h2><p>Teste com valores próximos da sua realidade para comparar cenários.</p><h2>Calculadoras relacionadas</h2><ul><li><a href='/utilidades/dias-entre-datas'>dias entre datas</a></li><li><a href='/utilidades/regra-de-tres'>regra de tres</a></li><li><a href='/utilidades/porcentagem'>porcentagem</a></li><li><a href='/utilidades'>Ver categoria utilidades</a></li><li><a href='/blog'>Ver blog</a></li></ul><FAQSection items={faqItems} /><FAQSchema items={faqItems} /></section><script>calc.onclick=()=>{const n=new Date(dn.value),r=new Date(dr.value||Date.now());let anos=r.getFullYear()-n.getFullYear(),meses=r.getMonth()-n.getMonth(),dias=r.getDate()-n.getDate();if(dias<0){meses--;dias+=30}if(meses<0){anos--;meses+=12}res.textContent=`${anos} anos`;det.textContent=`${anos} anos, ${meses} meses e ${dias} dias`;};</script></BaseLayout>