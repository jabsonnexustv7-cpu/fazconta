---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import AdSlot from '../../components/AdSlot.astro';
const faqItems=[{question:'O resultado é oficial?',answer:'Não. É uma simulação para planejamento.'},{question:'Posso usar no celular?',answer:'Sim, a calculadora funciona em dispositivos móveis.'},{question:'Este cálculo substitui análise profissional?',answer:'Não. Use como apoio e valide condições reais.'},{question:'Os valores têm arredondamento?',answer:'Sim, para facilitar leitura em reais e percentuais.'}];
---
<BaseLayout title="Calculadora de IMC | FazConta" description="Calcule IMC e classificação de faixa."><section class='container section'><Breadcrumb items={[{label:'Início',href:'/'},{label:'Utilidades',href:'/utilidades'},{label:'Calculadora de IMC'}]} /><h1>Calculadora de IMC</h1><p class='lead'>Calcule IMC e classificação de faixa.</p><p class='help-text'><strong>Aviso:</strong> cálculo estimativo para planejamento.</p><AdSlot /><div class='form-grid'><label>Peso (kg)<input id='p' type='number' step='0.01' value='70'></label><label>Altura (m)<input id='h' type='number' step='0.01' value='1.7'></label></div><button class='btn' id='calc'>Calcular</button><div class='result-card'><p class='result-title'>Resultado</p><p class='result-value' id='res'>-</p><p class='result-detail' id='det'></p></div><h2>Como usar esta calculadora</h2><p>Preencha os campos com seus valores reais e clique em calcular.</p><h2>Como o cálculo é feito</h2><p>Aplicamos fórmula financeira/matemática padrão com exibição do breakdown.</p><h2>Exemplo prático</h2><p>Teste com valores próximos da sua realidade para comparar cenários.</p><h2>Calculadoras relacionadas</h2><ul><li><a href='/saude/tmb'>tmb</a></li><li><a href='/utilidades/porcentagem'>porcentagem</a></li><li><a href='/utilidades/conversor-medidas'>conversor medidas</a></li><li><a href='/utilidades'>Ver categoria utilidades</a></li><li><a href='/blog'>Ver blog</a></li></ul><FAQSection items={faqItems} /><FAQSchema items={faqItems} /></section><script>calc.onclick=()=>{const imc=(+p.value||0)/Math.pow(+h.value||1,2);let fx=imc<18.5?'Abaixo do peso':imc<25?'Peso adequado':imc<30?'Sobrepeso':'Obesidade';res.textContent=imc.toFixed(2);det.textContent=`Classificação: ${fx}`;};</script></BaseLayout>