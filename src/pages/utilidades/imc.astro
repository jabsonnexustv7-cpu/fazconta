---import BaseLayout from '../../layouts/BaseLayout.astro';import FAQSection from '../../components/FAQSection.astro';import AdSlot from '../../components/AdSlot.astro';---
<BaseLayout title="Calculadora de IMC | FazConta" description="Calcule IMC, classificação e faixa de peso ideal."><section class="container section calc-layout"><article class="calc-form"><h1>Calculadora de IMC</h1><AdSlot /><div class="form-grid"><label>Peso (kg)<input id="p" type="number" step="0.1" /></label><label>Altura (cm)<input id="a" type="number" /></label></div><button class="btn" id="c">Calcular</button></article><aside class="calc-result"><div class="result-card"><p class="result-title">IMC</p><p class="result-value" id="r">0</p><p id="d" class="result-detail"></p></div><AdSlot /></aside></section><script>c.onclick=()=>{const peso=+p.value||0,h=(+a.value||0)/100,imc=peso/(h*h);let cls='Obesidade';if(imc<18.5)cls='Baixo peso';else if(imc<25)cls='Peso normal';else if(imc<30)cls='Sobrepeso';r.textContent=imc.toFixed(1);d.textContent=`Classificação: ${cls} · Faixa ideal estimada: ${(18.5*h*h).toFixed(1)}kg a ${(24.9*h*h).toFixed(1)}kg`;}</script><div class="container"><FAQSection items={[{question:'IMC serve para todos?',answer:'É indicador geral.'},{question:'Altura em cm?',answer:'Sim.'},{question:'Faixa ideal inclusa?',answer:'Sim.'},{question:'Substitui médico?',answer:'Não.'}]} /></div></BaseLayout>
