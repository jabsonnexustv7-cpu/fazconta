---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'FazConta | Calculadoras trabalhistas e financeiras',
  description = 'FazConta oferece calculadoras trabalhistas e financeiras rápidas, precisas e gratuitas.',
  canonical = Astro.url.href
} = Astro.props;

const socialImage = '/assets/branding/fazconta-open-graph-1200x630.png';
const favicon512 = '/assets/branding/fazconta-favicon-512.png';
const appleTouchIcon = '/assets/branding/fazconta-icon-transparent.png';
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2563eb" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="512x512" href={favicon512} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="FazConta" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="FazConta - Calculadoras simples para o dia a dia" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content="FazConta - Calculadoras simples para o dia a dia" />
  </head>
  <body>
    <Header />
    <main class="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
